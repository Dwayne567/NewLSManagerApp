@using Microsoft.AspNetCore.Identity
@using LinkshellManagerDiscordApp.Data
@using Microsoft.EntityFrameworkCore
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager
@inject ApplicationDbContext DbContext

@{
    var isSignedIn = SignInManager.IsSignedIn(User);
    AppUser? currentUser = isSignedIn ? await UserManager.GetUserAsync(User) : null;
    var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
    var profileImage = currentUser?.ProfileImage is { Length: > 0 }
        ? $"data:image/png;base64,{Convert.ToBase64String(currentUser.ProfileImage)}"
        : null;

    string? activeLinkshellName = null;
    string? activeLinkshellInitials = null;
    string? activeRole = null;
    if (currentUser is not null && currentUser.PrimaryLinkshellId.HasValue)
    {
        var ls = await DbContext.Linkshells
            .AsNoTracking()
            .FirstOrDefaultAsync(l => l.Id == currentUser.PrimaryLinkshellId.Value);
        if (ls is not null)
        {
            activeLinkshellName = ls.LinkshellName;
            activeLinkshellInitials = string.Concat(
                (ls.LinkshellName ?? "LS")
                    .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                    .Select(w => w[0]))
                .ToUpperInvariant();
            if (activeLinkshellInitials.Length > 2)
            {
                activeLinkshellInitials = activeLinkshellInitials[..2];
            }

            var membership = await DbContext.AppUserLinkshells
                .AsNoTracking()
                .FirstOrDefaultAsync(link =>
                    link.AppUserId == currentUser.Id &&
                    link.LinkshellId == currentUser.PrimaryLinkshellId.Value);
            activeRole = membership?.Rank;
        }
    }

    ViewData["ActiveLinkshellName"] = activeLinkshellName;
    ViewData["ActiveLinkshellInitials"] = activeLinkshellInitials;
    ViewData["ActiveRole"] = activeRole;

    var displayName = currentUser?.CharacterName ?? currentUser?.UserName ?? "User";
    var avatarInitials = string.Concat(
            (displayName ?? "U")
                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .Select(w => w[0]))
            .ToUpperInvariant();
    if (string.IsNullOrEmpty(avatarInitials)) { avatarInitials = "U"; }
    if (avatarInitials.Length > 2) { avatarInitials = avatarInitials[..2]; }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle · LinkshellManager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @if (isSignedIn && currentUser is not null)
    {
        <div class="app">
            <partial name="_Sidebar" />

            <div class="main">
                <div class="topbar">
                    <div class="crumbs">
                        @if (!string.IsNullOrWhiteSpace(activeLinkshellName))
                        {
                            <span>@activeLinkshellName</span>
                            <span class="sep">/</span>
                        }
                        <span class="here">@pageTitle</span>
                    </div>

                    <div class="topbar-actions">
                        <button type="button" class="search" aria-label="Search">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
                            <span>Search…</span>
                            <kbd>⌘K</kbd>
                        </button>
                        <button type="button" class="icon-btn" title="Notifications" aria-label="Notifications">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M6 8a6 6 0 1 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10 21a2 2 0 0 0 4 0"/></svg>
                        </button>
                        <a class="avatar-btn" asp-controller="Account" asp-action="Profile" title="Profile">
                            @if (profileImage is not null)
                            {
                                <img class="avatar-img" src="@profileImage" alt="" />
                            }
                            else
                            {
                                <span class="avatar">@avatarInitials</span>
                            }
                            <span class="avatar-name">@displayName</span>
                        </a>
                        <a class="icon-btn" asp-controller="Account" asp-action="Logout" title="Sign out" aria-label="Sign out">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M15 4h4a1 1 0 0 1 1 1v14a1 1 0 0 1-1 1h-4"/><path d="M10 17l-5-5 5-5"/><path d="M5 12h11"/></svg>
                        </a>
                    </div>
                </div>

                <div class="content">
                    @RenderBody()
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="auth-shell">
            @RenderBody()
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/sidebar.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
