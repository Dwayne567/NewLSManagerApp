@model IEnumerable<EventViewModel>
@{
    ViewData["Title"] = "Events";
    var currentCharacter = ViewBag.CharacterName as string;

    string RelativeTime(DateTime? when)
    {
        if (!when.HasValue) return "TBD";
        var delta = when.Value - DateTime.UtcNow;
        var abs = delta.Duration();
        var prefix = delta.TotalSeconds < 0 ? "" : "in ";
        var suffix = delta.TotalSeconds < 0 ? " ago" : "";
        if (abs.TotalMinutes < 60) return $"{prefix}{(int)abs.TotalMinutes}m{suffix}";
        if (abs.TotalHours < 24) return $"{prefix}{(int)abs.TotalHours}h{suffix}";
        if (abs.TotalDays < 14) return $"{prefix}{(int)abs.TotalDays}d{suffix}";
        return when.Value.ToString("MMM d");
    }
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">Event System</h1>
        <div class="page-sub">
            <span><span class="num">@Model.Count()</span> active</span>
            <span class="live-dot">Live</span>
        </div>
    </div>
    <div class="page-actions">
        <a class="btn primary" asp-action="Create">+ Create event</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card fade d2">
        <div class="empty">
            <div style="font-size:15px;color:var(--fg);font-weight:500;margin-bottom:6px">No active events</div>
            <div style="margin-bottom:12px">Create your first event to begin scheduling linkshell runs.</div>
            <a class="btn primary" asp-action="Create">Create event</a>
        </div>
    </div>
}
else
{
    <div class="fade d2" style="display:grid;gap:16px">
        @foreach (var item in Model)
        {
            var signedUp = item.AppUserEvents.Any(entry => entry.CharacterName == currentCharacter);
            var isLive = item.Event.CommencementStartTime.HasValue;
            <div class="card">
                <div class="card-head">
                    <div style="display:flex;flex-direction:column;gap:4px">
                        <div class="card-title">
                            @item.Event.EventName
                            @if (!string.IsNullOrWhiteSpace(item.Event.EventType))
                            {
                                <span class="tag">@item.Event.EventType</span>
                            }
                            @if (isLive)
                            {
                                <span class="tag success">Live</span>
                            }
                        </div>
                        <div style="font-size:12px;color:var(--fg-3)">
                            @if (!string.IsNullOrWhiteSpace(item.Event.EventLocation))
                            {
                                <span>@item.Event.EventLocation</span>
                                <span class="dot"> · </span>
                            }
                            <span>@(item.Event.StartTime?.ToString("ddd MMM d, HH:mm") ?? "Start TBD")</span>
                            <span class="dot"> · </span>
                            <span>@RelativeTime(item.Event.StartTime)</span>
                            <span class="dot"> · </span>
                            <span>by @(item.CreatorCharacterName ?? "Unknown")</span>
                        </div>
                    </div>
                    <div style="display:flex;gap:6px;flex-wrap:wrap">
                        @if (isLive)
                        {
                            <a class="btn primary sm" asp-action="Start" asp-route-eventId="@item.Event.Id">Resume</a>
                        }
                        else
                        {
                            <form asp-action="StartEvent" method="post" style="display:inline">
                                <input type="hidden" name="eventId" value="@item.Event.Id" />
                                <button class="btn primary sm" type="submit">Start</button>
                            </form>
                        }
                        <a class="btn ghost sm" asp-action="Edit" asp-route-id="@item.Event.Id">Edit</a>
                        <a class="btn ghost sm" asp-action="Delete" asp-route-id="@item.Event.Id">Delete</a>
                    </div>
                </div>

                @if (!string.IsNullOrWhiteSpace(item.Event.Details))
                {
                    <div style="padding:0 16px 12px;color:var(--fg-3);font-size:13px">@item.Event.Details</div>
                }

                @if (item.Jobs.Count > 0)
                {
                    <table class="table themed">
                        <thead>
                            <tr>
                                <th>Job</th>
                                <th>Role</th>
                                <th>Qty</th>
                                <th>Signed</th>
                                <th>Roster</th>
                                <th style="text-align:right">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var job in item.Jobs)
                            {
                                var onThisJob = item.AppUserEvents.Any(entry => entry.CharacterName == currentCharacter && entry.JobName == job.JobName && entry.SubJobName == job.SubJobName);
                                <tr>
                                    <td>@job.JobName/@job.SubJobName</td>
                                    <td><span class="tag">@job.JobType</span></td>
                                    <td>@(job.Quantity ?? 0)</td>
                                    <td>@(job.SignedUp ?? 0)</td>
                                    <td style="color:var(--fg-3);font-size:12px">@(job.Enlisted.Count > 0 ? string.Join(", ", job.Enlisted) : "—")</td>
                                    <td style="text-align:right">
                                        @if (onThisJob)
                                        {
                                            <form asp-action="Unsign" method="post" style="display:inline">
                                                <input type="hidden" name="jobId" value="@job.Id" />
                                                <input type="hidden" name="eventId" value="@item.Event.Id" />
                                                <button class="btn ghost sm" type="submit">Unsign</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form asp-action="SignUp" method="post" style="display:inline">
                                                <input type="hidden" name="jobId" value="@job.Id" />
                                                <input type="hidden" name="eventId" value="@item.Event.Id" />
                                                <button class="btn primary sm" type="submit">Sign up</button>
                                            </form>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <div style="padding:12px 16px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;font-size:12px;color:var(--fg-3)">
                    <span><span class="num">@item.AppUserEvents.Count</span> participants @(signedUp ? "· you are signed up" : "")</span>
                </div>
            </div>
        }
    </div>
}
