@model Event
@{
    ViewData["Title"] = "Delete event";
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">Delete event</h1>
        <div class="page-sub"><span>Confirm removal of this event</span></div>
    </div>
    <div class="page-actions">
        <a class="btn ghost" asp-action="Index">Cancel</a>
    </div>
</div>

<div class="card fade d2" style="padding:20px;max-width:560px">
    <div class="alert alert-danger" style="margin-bottom:16px">
        This will remove <strong>@Model.EventName</strong> and any live signup state for it. This cannot be undone.
    </div>
    <form asp-action="DeleteConfirmed" method="post" style="display:flex;gap:8px">
        <input type="hidden" name="id" value="@Model.Id" />
        <button class="btn primary" type="submit" style="background:var(--danger);border-color:var(--danger)">Delete event</button>
        <a class="btn ghost" asp-action="Index">Cancel</a>
    </form>
</div>
