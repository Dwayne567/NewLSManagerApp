@model EventViewModel
@{
    ViewData["Title"] = "Create event";
    var mainJobOptionsJson = System.Text.Json.JsonSerializer.Serialize(LinkshellManagerDiscordApp.Utils.EventJobCatalog.MainJobOptions);
    var subJobOptionsJson = System.Text.Json.JsonSerializer.Serialize(LinkshellManagerDiscordApp.Utils.EventJobCatalog.SubJobOptions);
    var typeOptionsJson = System.Text.Json.JsonSerializer.Serialize(LinkshellManagerDiscordApp.Utils.EventJobCatalog.JobTypeOptions);
}

<div class="row justify-content-center">
    <div class="col-xl-10">
        <div class="card card-shell shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">Create event</h1>
                <form asp-action="Create" method="post">
                    @await Html.PartialAsync("_EventForm", Model)
                    <div class="col-12 d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary">Save event</button>
                        <a class="btn btn-outline-light" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const mainJobOptions = @Html.Raw(mainJobOptionsJson);
    const subJobOptions = @Html.Raw(subJobOptionsJson);
    const typeOptions = @Html.Raw(typeOptionsJson);
    const container = document.getElementById('jobs-container');
    const addButton = document.getElementById('add-job');
    const buildOptions = (options, placeholder) => [
        `<option value="">${placeholder}</option>`,
        ...options.map(option => `<option value="${option}">${option}</option>`)
    ].join('');

    function reindex() {
        const rows = container.querySelectorAll('.job-row');
        rows.forEach((row, index) => {
            row.querySelectorAll('input, select').forEach(field => {
                field.name = field.name.replace(/Jobs\[\d+\]/, `Jobs[${index}]`);
            });
        });
    }
    addButton.addEventListener('click', () => {
        const index = container.querySelectorAll('.job-row').length;
        const wrapper = document.createElement('div');
        wrapper.className = 'border rounded p-3 job-row';
        wrapper.innerHTML = `
            <div class="row g-2 align-items-end">
                <div class="col-md-3"><label class="form-label">Main job</label><select class="form-select" name="Jobs[${index}].JobName">${buildOptions(mainJobOptions, 'Select main job')}</select></div>
                <div class="col-md-3"><label class="form-label">Sub job</label><select class="form-select" name="Jobs[${index}].SubJobName">${buildOptions(subJobOptions, 'Select sub job')}</select></div>
                <div class="col-md-2"><label class="form-label">Type</label><select class="form-select" name="Jobs[${index}].JobType">${buildOptions(typeOptions, 'Select type')}</select></div>
                <div class="col-md-2"><label class="form-label">Quantity</label><input class="form-control" type="number" name="Jobs[${index}].Quantity" /></div>
                <div class="col-md-2"><button class="btn btn-outline-danger w-100 remove-job" type="button">Remove</button></div>
                <div class="col-12"><label class="form-label">Details</label><input class="form-control" name="Jobs[${index}].Details" /></div>
            </div>`;
        container.appendChild(wrapper);
    });
    container.addEventListener('click', event => {
        const button = event.target.closest('.remove-job');
        if (!button) return;
        button.closest('.job-row')?.remove();
        reindex();
    });
})();
</script>
}
