@model EventViewModel
@{
    var jobs = Model.Jobs.Count > 0 ? Model.Jobs : new List<Job> { new() };
    var mainJobOptions = LinkshellManagerDiscordApp.Utils.EventJobCatalog.MainJobOptions;
    var subJobOptions = LinkshellManagerDiscordApp.Utils.EventJobCatalog.SubJobOptions;
    var typeOptions = LinkshellManagerDiscordApp.Utils.EventJobCatalog.JobTypeOptions;
}

<div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom:12px"></div>

<div class="form-grid">
    <div class="field">
        <label for="Event_LinkshellId">Linkshell</label>
        <select class="form-select" id="Event_LinkshellId" name="Event.LinkshellId">
            @foreach (var linkshell in Model.Linkshells)
            {
                if (linkshell.Id == Model.Event.LinkshellId)
                {
                    <option value="@linkshell.Id" selected>@linkshell.LinkshellName</option>
                }
                else
                {
                    <option value="@linkshell.Id">@linkshell.LinkshellName</option>
                }
            }
        </select>
    </div>
    <div class="field">
        <label for="Event_EventName">Name</label>
        <input class="form-control" id="Event_EventName" name="Event.EventName" value="@Model.Event.EventName" />
    </div>
    <div class="field">
        <label for="Event_EventType">Type</label>
        <input class="form-control" id="Event_EventType" name="Event.EventType" value="@Model.Event.EventType" />
    </div>
    <div class="field">
        <label for="Event_EventLocation">Location</label>
        <input class="form-control" id="Event_EventLocation" name="Event.EventLocation" value="@Model.Event.EventLocation" />
    </div>
    <div class="field">
        <label for="Event_DkpPerHour">DKP per hour</label>
        <input class="form-control" id="Event_DkpPerHour" name="Event.DkpPerHour" type="number" value="@Model.Event.DkpPerHour" />
    </div>
    <div class="field">
        <label for="Event_Duration">Planned hours</label>
        <input class="form-control" id="Event_Duration" name="Event.Duration" type="number" step="0.25" value="@Model.Event.Duration" />
    </div>
    <div class="field">
        <label for="Event_StartTime">Start</label>
        <input class="form-control" id="Event_StartTime" name="Event.StartTime" type="datetime-local" value="@(Model.Event.StartTime?.ToString("yyyy-MM-ddTHH:mm"))" />
    </div>
    <div class="field">
        <label for="Event_EndTime">End</label>
        <input class="form-control" id="Event_EndTime" name="Event.EndTime" type="datetime-local" value="@(Model.Event.EndTime?.ToString("yyyy-MM-ddTHH:mm"))" />
    </div>
    <div class="field" style="grid-column:1/-1">
        <label for="Event_Details">Details</label>
        <textarea class="form-control" id="Event_Details" name="Event.Details" rows="4">@Model.Event.Details</textarea>
    </div>
</div>

<div style="display:flex;justify-content:space-between;align-items:center;margin-top:20px;margin-bottom:12px">
    <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0">Minimal party setup <span style="color:var(--fg-3);font-weight:400">(optional)</span></h2>
    <button class="btn ghost sm" type="button" id="add-job">+ Add job</button>
</div>

<div id="jobs-container" style="display:grid;gap:12px">
    @for (var i = 0; i < jobs.Count; i++)
    {
        <div class="card job-row" style="padding:12px">
            <div class="form-grid">
                <div class="field">
                    <label>Role</label>
                    <select class="form-select" name="Jobs[@i].JobType">
                        <option value="">Select role</option>
                        @foreach (var typeOption in typeOptions)
                        {
                            if (string.Equals(jobs[i].JobType, typeOption, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@typeOption" selected>@typeOption</option>
                            }
                            else
                            {
                                <option value="@typeOption">@typeOption</option>
                            }
                        }
                    </select>
                </div>
                <div class="field">
                    <label>Main job</label>
                    <select class="form-select" name="Jobs[@i].JobName">
                        <option value="">Select main job</option>
                        @foreach (var jobOption in mainJobOptions)
                        {
                            if (string.Equals(jobs[i].JobName, jobOption, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@jobOption" selected>@jobOption</option>
                            }
                            else
                            {
                                <option value="@jobOption">@jobOption</option>
                            }
                        }
                    </select>
                </div>
                <div class="field">
                    <label>Sub job</label>
                    <select class="form-select" name="Jobs[@i].SubJobName">
                        <option value="">Select sub job</option>
                        @foreach (var jobOption in subJobOptions)
                        {
                            if (string.Equals(jobs[i].SubJobName, jobOption, StringComparison.OrdinalIgnoreCase))
                            {
                                <option value="@jobOption" selected>@jobOption</option>
                            }
                            else
                            {
                                <option value="@jobOption">@jobOption</option>
                            }
                        }
                    </select>
                </div>
                <div class="field">
                    <label>Quantity</label>
                    <input class="form-control" name="Jobs[@i].Quantity" type="number" value="@jobs[i].Quantity" />
                </div>
                <div class="field" style="grid-column:1/-1">
                    <label>Details</label>
                    <input class="form-control" name="Jobs[@i].Details" value="@jobs[i].Details" />
                </div>
                <div class="field" style="grid-column:1/-1;align-items:flex-end">
                    <button class="btn ghost sm remove-job" type="button">Remove job</button>
                </div>
            </div>
        </div>
    }
</div>
