@using System.Globalization
@using System.Security.Claims
@model EventViewModel
@{
    ViewData["Title"] = "Active event";
    var mainJobOptions = LinkshellManagerDiscordApp.Utils.EventJobCatalog.MainJobOptions;
    var subJobOptions = LinkshellManagerDiscordApp.Utils.EventJobCatalog.SubJobOptions;
    var jobTypeOptions = LinkshellManagerDiscordApp.Utils.EventJobCatalog.JobTypeOptions;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    string ToLocalIso(DateTime? value) => value?.ToString("yyyy-MM-ddTHH:mm:ss", CultureInfo.InvariantCulture) ?? string.Empty;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">@Model.Event.EventName</h1>
        <p class="text-muted mb-0">Live event management, attendance verification, and loot entry.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-light" asp-action="Index">Back to events</a>
    </div>
</div>

<div
    class="card card-shell shadow-sm mb-4"
    data-live-event-dashboard
    data-event-start-local="@ToLocalIso(Model.CommencementStartTime)"
    data-dkp-per-hour="@(Model.Event.DkpPerHour?.ToString(CultureInfo.InvariantCulture) ?? "0")"
    data-planned-hours="@(Model.Event.Duration?.ToString(CultureInfo.InvariantCulture) ?? string.Empty)">
    <div class="card-body d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
        <div>
            <h2 class="h5 mb-1">Global Timer</h2>
            <p class="text-muted mb-0">Starts when the event goes live and keeps the active event clock in sync.</p>
        </div>
        <div class="text-lg-end">
            <div class="display-6 fw-semibold" data-live-event-timer>00:00:00</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-4">
        <div class="card card-shell shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5 mb-3">Event details</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-5">Type</dt><dd class="col-sm-7">@Model.Event.EventType</dd>
                    <dt class="col-sm-5">Location</dt><dd class="col-sm-7">@Model.Event.EventLocation</dd>
                    <dt class="col-sm-5">Started</dt><dd class="col-sm-7">@(Model.CommencementStartTime?.ToString("g") ?? "Not started")</dd>
                    <dt class="col-sm-5">DKP/hour</dt><dd class="col-sm-7">@(Model.Event.DkpPerHour ?? 0)</dd>
                </dl>
                @if (!string.IsNullOrWhiteSpace(Model.Event.Details))
                {
                    <hr />
                    <p class="text-muted mb-0">@Model.Event.Details</p>
                }
            </div>
        </div>
    </div>
    <div class="col-xl-8">
        <div class="card card-shell shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">Participants</h2>
                    <span class="badge badge-soft">@Model.AppUserEvents.Count connected</span>
                </div>
                @if (Model.AppUserEvents.Count == 0)
                {
                    <p class="text-muted mb-0">No participants yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle">
                            <thead>
                                <tr>
                                    <th>Character</th>
                                    <th>Job</th>
                                    <th>Role</th>
                                    <th>Joined</th>
                                    <th>Timer</th>
                                    <th>Progress</th>
                                    <th>DKP</th>
                                    <th>Verified</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                            @foreach (var participant in Model.AppUserEvents)
                            {
                                <tr
                                    data-live-participant
                                    data-participant-start-local="@ToLocalIso(participant.StartTime)"
                                    data-participant-resume-local="@ToLocalIso(participant.ResumeTime)"
                                    data-participant-base-hours="@(participant.Duration?.ToString(CultureInfo.InvariantCulture) ?? "0")"
                                    data-participant-on-break="@((participant.IsOnBreak == true).ToString().ToLowerInvariant())">
                                    <td>@participant.CharacterName</td>
                                    <td>@participant.JobName/@participant.SubJobName</td>
                                    <td>@(participant.JobType ?? "Role")</td>
                                    <td>@(participant.StartTime?.ToString("g") ?? "Pending")</td>
                                    <td class="text-nowrap" data-live-participant-timer>00:00:00</td>
                                    <td style="min-width: 180px;">
                                        <div class="progress" style="height: 0.6rem;">
                                            <div
                                                class="progress-bar bg-info"
                                                role="progressbar"
                                                style="width: 0%;"
                                                aria-valuemin="0"
                                                aria-valuemax="100"
                                                data-live-participant-progress></div>
                                        </div>
                                    </td>
                                    <td class="text-nowrap" data-live-participant-dkp>0.00</td>
                                    <td>
                                        @if (participant.IsOnBreak == true)
                                        {
                                            <span class="badge bg-warning text-dark">On break</span>
                                        }
                                        else if (participant.IsVerified == true)
                                        {
                                            <span class="badge bg-success">Verified attendance</span>
                                        }
                                        else if (participant.IsVerified == false)
                                        {
                                            <span class="badge bg-danger">Attendance denied</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Pending attendance</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            @if (participant.AppUserId == currentUserId)
                                            {
                                                @if (participant.IsOnBreak == true)
                                                {
                                                    <form asp-action="ReturnFromBreak" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="eventId" value="@Model.Event.Id" />
                                                        <button class="btn btn-outline-info btn-sm" type="submit">Return</button>
                                                    </form>
                                                }
                                                else
                                                {
                                                    <form asp-action="TakeBreak" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="eventId" value="@Model.Event.Id" />
                                                        <button class="btn btn-outline-info btn-sm" type="submit">Take break</button>
                                                    </form>
                                                }
                                            }
                                            @if (participant.IsVerified is null)
                                            {
                                                <form asp-action="VerifyUser" method="post" class="d-inline">
                                                    <input type="hidden" name="eventId" value="@Model.Event.Id" />
                                                    <input type="hidden" name="characterName" value="@participant.CharacterName" />
                                                    <input type="hidden" name="isVerified" value="true" />
                                                    <button class="btn btn-outline-success btn-sm" type="submit">Present</button>
                                                </form>
                                                <form asp-action="VerifyUser" method="post" class="d-inline">
                                                    <input type="hidden" name="eventId" value="@Model.Event.Id" />
                                                    <input type="hidden" name="characterName" value="@participant.CharacterName" />
                                                    <input type="hidden" name="isVerified" value="false" />
                                                    <button class="btn btn-outline-danger btn-sm" type="submit">Absent</button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="UndoVerification" method="post" class="d-inline">
                                                    <input type="hidden" name="eventId" value="@Model.Event.Id" />
                                                    <input type="hidden" name="characterName" value="@participant.CharacterName" />
                                                    <button class="btn btn-outline-warning btn-sm" type="submit">Undo</button>
                                                </form>
                                            }
                                        </div>
                                        @if (participant.StatusLedgerEntries.Count > 0)
                                        {
                                            <ul class="list-unstyled small text-muted mt-2 mb-0">
                                                @foreach (var entry in participant.StatusLedgerEntries)
                                                {
                                                    <li class="mb-1">
                                                        <div class="d-flex justify-content-end align-items-start gap-2">
                                                            <div class="text-end">
                                                                <strong class="d-block text-light">
                                                                    @(entry.ActionType == "BreakStart" ? "Break started" :
                                                                      entry.ActionType == "BreakReturn" ? "Returned from break" :
                                                                      entry.ActionType)
                                                                </strong>
                                                                <span class="d-block">@entry.OccurredAt.ToString("g")</span>
                                                                @if (entry.VerifiedAt.HasValue)
                                                                {
                                                                    <span class="d-block">Verified by @(entry.VerifiedBy ?? "Officer") at @entry.VerifiedAt.Value.ToString("g")</span>
                                                                }
                                                                else if (entry.RequiresVerification)
                                                                {
                                                                    <span class="d-block">Awaiting return verification</span>
                                                                }
                                                            </div>
                                                            @if (entry.ActionType == "BreakReturn" && entry.RequiresVerification && !entry.VerifiedAt.HasValue)
                                                            {
                                                                <form asp-action="VerifyReturn" method="post" class="d-inline">
                                                                    @Html.AntiForgeryToken()
                                                                    <input type="hidden" name="eventId" value="@Model.Event.Id" />
                                                                    <input type="hidden" name="ledgerEntryId" value="@entry.Id" />
                                                                    <button class="btn btn-outline-info btn-sm" type="submit">Verify return</button>
                                                                </form>
                                                            }
                                                        </div>
                                                    </li>
                                                }
                                            </ul>
                                        }
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-xl-6">
        <div class="card card-shell shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5 mb-3">Quick join</h2>
                <form asp-action="QuickJoin" method="post" class="row g-3">
                    <input type="hidden" name="eventId" value="@Model.Event.Id" />
                    <div class="col-md-4">
                        <label class="form-label">Job</label>
                        <select class="form-select" name="jobName">
                            <option value="">Select main job</option>
                            @foreach (var jobOption in mainJobOptions)
                            {
                                <option value="@jobOption">@jobOption</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Sub job</label>
                        <select class="form-select" name="subJobName">
                            <option value="">Select sub job</option>
                            @foreach (var jobOption in subJobOptions)
                            {
                                <option value="@jobOption">@jobOption</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Type</label>
                        <select class="form-select" name="jobType">
                            <option value="">Select type</option>
                            @foreach (var jobTypeOption in jobTypeOptions)
                            {
                                <option value="@jobTypeOption">@jobTypeOption</option>
                            }
                        </select>
                    </div>
                    <div class="col-12"><button class="btn btn-outline-light" type="submit">Join active event</button></div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-xl-6">
        <div class="card card-shell shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5 mb-3">Loot log</h2>
                <form asp-action="SubmitLootDetails" method="post" class="row g-3 mb-4">
                    <input type="hidden" name="eventId" value="@Model.Event.Id" />
                    <div class="col-md-5"><label class="form-label">Item</label><input class="form-control" name="itemName" /></div>
                    <div class="col-md-4">
                        <label class="form-label">Winner</label>
                        <select class="form-select" name="itemWinner">
                            <option value="">Select event member</option>
                            @foreach (var participantName in Model.AppUserEvents
                                .Select(item => item.CharacterName)
                                .Where(name => !string.IsNullOrWhiteSpace(name))
                                .Distinct()
                                .OrderBy(name => name))
                            {
                                <option value="@participantName">@participantName</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3"><label class="form-label">Spent</label><input class="form-control" name="winningDkpSpent" type="number" value="0" /></div>
                    <div class="col-12"><button class="btn btn-outline-light" type="submit">Add loot</button></div>
                </form>
                @if (Model.EventLootDetails.Count == 0)
                {
                    <p class="text-muted mb-0">No loot logged yet.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead><tr><th>Item</th><th>Winner</th><th class="text-end">Spent</th></tr></thead>
                            <tbody>
                            @foreach (var loot in Model.EventLootDetails)
                            {
                                <tr><td>@loot.ItemName</td><td>@loot.ItemWinner</td><td class="text-end">@loot.WinningDkpSpent</td></tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-12">
        <div class="card card-shell shadow-sm border-warning">
            <div class="card-body d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                <div>
                    <h2 class="h5 mb-1">Complete this event</h2>
                    <p class="text-muted mb-0">This rolls the live event into event history, calculates participant DKP, and updates linkshell totals.</p>
                </div>
                <form asp-action="EndEvent" method="post">
                    <input type="hidden" name="eventId" value="@Model.Event.Id" />
                    <button class="btn btn-warning" type="submit">End event</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const dashboard = document.querySelector('[data-live-event-dashboard]');
            if (!dashboard) {
                return;
            }

            const parseLocalDate = (value) => {
                if (!value) {
                    return null;
                }

                const parsed = new Date(value);
                return Number.isNaN(parsed.getTime()) ? null : parsed;
            };

            const formatElapsed = (totalMilliseconds) => {
                const totalSeconds = Math.max(0, Math.floor(totalMilliseconds / 1000));
                const hours = Math.floor(totalSeconds / 3600);
                const minutes = Math.floor((totalSeconds % 3600) / 60);
                const seconds = totalSeconds % 60;
                return [hours, minutes, seconds].map(value => value.toString().padStart(2, '0')).join(':');
            };

            const eventStart = parseLocalDate(dashboard.dataset.eventStartLocal);
            const dkpPerHour = Number.parseFloat(dashboard.dataset.dkpPerHour || '0') || 0;
            const plannedHours = Number.parseFloat(dashboard.dataset.plannedHours || '');
            const timerTarget = dashboard.querySelector('[data-live-event-timer]');
            const participantRows = Array.from(document.querySelectorAll('[data-live-participant]'));

            const update = () => {
                const now = new Date();
                const eventElapsedMs = eventStart ? Math.max(0, now.getTime() - eventStart.getTime()) : 0;

                if (timerTarget) {
                    timerTarget.textContent = formatElapsed(eventElapsedMs);
                }

                for (const row of participantRows) {
                    const participantStart = parseLocalDate(row.dataset.participantStartLocal);
                    const participantResume = parseLocalDate(row.dataset.participantResumeLocal);
                    const participantBaseHours = Number.parseFloat(row.dataset.participantBaseHours || '0') || 0;
                    const participantOnBreak = row.dataset.participantOnBreak === 'true';
                    const segmentStart = participantResume || participantStart || eventStart;
                    const participantElapsedMs = (participantBaseHours * 3600000)
                        + (participantOnBreak ? 0 : (segmentStart ? Math.max(0, now.getTime() - segmentStart.getTime()) : 0));
                    const participantDkp = (participantElapsedMs / 3600000) * dkpPerHour;
                    const progress = Number.isFinite(plannedHours) && plannedHours > 0
                        ? Math.min(100, (participantElapsedMs / (plannedHours * 3600000)) * 100)
                        : 0;

                    const timerCell = row.querySelector('[data-live-participant-timer]');
                    const dkpCell = row.querySelector('[data-live-participant-dkp]');
                    const progressBar = row.querySelector('[data-live-participant-progress]');

                    if (timerCell) {
                        timerCell.textContent = formatElapsed(participantElapsedMs);
                    }

                    if (dkpCell) {
                        dkpCell.textContent = participantDkp.toFixed(2);
                    }

                    if (progressBar) {
                        progressBar.style.width = `${progress}%`;
                        progressBar.setAttribute('aria-valuenow', progress.toFixed(0));
                    }
                }
            };

            update();
            window.setInterval(update, 1000);
        })();
    </script>
}
