@model LinkshellManagerDiscordApp.ViewModels.DkpHistoryViewModel
@{
    ViewData["Title"] = "DKP history";
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">DKP History</h1>
        <div class="page-sub">
            <span>Earned and spent ledger</span>
            @if (!string.IsNullOrWhiteSpace(Model.SelectedLinkshellName))
            {
                <span>·</span>
                <span>@Model.SelectedLinkshellName</span>
            }
        </div>
    </div>
    <div class="page-actions">
        <a class="btn ghost" asp-controller="Dashboard" asp-action="Index">Back to dashboard</a>
    </div>
</div>

<div class="grid fade d2">
    <div class="col">
        <div class="card">
            <div class="card-head">
                <div class="card-title">Filters</div>
            </div>
            <div style="padding:4px 16px 16px">
                @if (!Model.Linkshells.Any())
                {
                    <div class="empty">Join a linkshell to unlock DKP history.</div>
                }
                else
                {
                    <form method="get">
                        <div class="field">
                            <label for="linkshellId">Linkshell</label>
                            <select class="form-select" id="linkshellId" name="linkshellId" onchange="this.form.submit()">
                                @foreach (var linkshell in Model.Linkshells)
                                {
                                    @if (Model.SelectedLinkshellId == linkshell.Id)
                                    {
                                        <option value="@linkshell.Id" selected>@linkshell.Name</option>
                                    }
                                    else
                                    {
                                        <option value="@linkshell.Id">@linkshell.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="field">
                            <label for="appUserId">Member</label>
                            <select class="form-select" id="appUserId" name="appUserId" onchange="this.form.submit()">
                                @foreach (var member in Model.Members)
                                {
                                    @if (Model.SelectedAppUserId == member.AppUserId)
                                    {
                                        <option value="@member.AppUserId" selected>@member.CharacterName (@member.CurrentBalance.ToString("0.##") DKP)</option>
                                    }
                                    else
                                    {
                                        <option value="@member.AppUserId">@member.CharacterName (@member.CurrentBalance.ToString("0.##") DKP)</option>
                                    }
                                }
                            </select>
                        </div>
                    </form>

                    <div style="margin-top:16px;padding-top:12px;border-top:1px solid var(--border);display:grid;grid-template-columns:110px 1fr;gap:8px 12px;font-size:13px">
                        <div style="color:var(--fg-3)">Member</div><div>@Model.SelectedMemberName</div>
                        <div style="color:var(--fg-3)">Balance</div><div class="num" style="font-weight:600">@Model.CurrentBalance.ToString("0.##")</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col">
        <div class="card">
            <div class="card-head">
                <div class="card-title">Ledger <span class="tag">@Model.Entries.Count</span></div>
            </div>
            @if (!Model.Entries.Any())
            {
                <div class="empty">No DKP transactions recorded for this member yet.</div>
            }
            else
            {
                <table class="table themed">
                    <thead>
                        <tr>
                            <th>When</th>
                            <th>Entry</th>
                            <th>Event</th>
                            <th>Details</th>
                            <th style="text-align:right">Amount</th>
                            <th style="text-align:right">Balance</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in Model.Entries)
                        {
                            var isSpent = entry.EntryType == "LootSpent";
                            var amountColor = entry.Amount >= 0 ? "var(--success)" : "var(--danger)";
                            <tr>
                                <td style="font-size:12px;color:var(--fg-3)">@(entry.OccurredAt?.ToString("g") ?? "—")</td>
                                <td>
                                    @if (isSpent)
                                    {
                                        <span class="tag danger">Spent</span>
                                    }
                                    else
                                    {
                                        <span class="tag success">Earned</span>
                                    }
                                </td>
                                <td>
                                    <div style="font-weight:500">@(entry.EventName ?? "Unknown event")</div>
                                    <div style="color:var(--fg-4);font-size:11px">
                                        @(entry.EventType ?? "Event") · @(entry.EventLocation ?? "—")
                                    </div>
                                    @if (entry.EventStartTime.HasValue || entry.EventEndTime.HasValue)
                                    {
                                        <div style="color:var(--fg-4);font-size:11px">@(entry.EventStartTime?.ToString("g") ?? "—") → @(entry.EventEndTime?.ToString("g") ?? "—")</div>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrWhiteSpace(entry.ItemName))
                                    {
                                        <div style="font-weight:500">@entry.ItemName</div>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(entry.Details))
                                    {
                                        <div style="color:var(--fg-4);font-size:11px">@entry.Details</div>
                                    }
                                </td>
                                <td style="text-align:right;font-family:var(--font-mono);color:@amountColor">@entry.Amount.ToString("+0.##;-0.##;0")</td>
                                <td style="text-align:right;font-family:var(--font-mono)" class="num">@entry.RunningBalance.ToString("0.##")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>
