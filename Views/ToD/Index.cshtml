@using System.Text.Json
@model LinkshellManagerDiscordApp.ViewModels.TodManagerViewModel

@{
    ViewData["Title"] = "ToD Manager";
    var selectedLinkshellName = Model.Linkshells.FirstOrDefault(item => item.Id == Model.LinkshellId)?.LinkshellName ?? "Selected Linkshell";
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">ToD Manager</h1>
        <div class="page-sub">
            <span>@selectedLinkshellName</span>
            <span>·</span>
            <span><span class="num">@Model.TodItems.Count</span> entries</span>
        </div>
    </div>

    @if (Model.Linkshells.Any())
    {
        <div class="page-actions">
            <select id="linkshell-filter" class="form-select">
                @foreach (var linkshell in Model.Linkshells)
                {
                    <option value="@linkshell.Id" selected="@(linkshell.Id == Model.LinkshellId ? "selected" : null)">@linkshell.LinkshellName</option>
                }
            </select>
        </div>
    }
</div>

@if (!Model.Linkshells.Any())
{
    <div class="card fade d2">
        <div class="empty">Join a linkshell before submitting a ToD entry.</div>
    </div>
}
else
{
    <div class="grid-2 fade d2" style="grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr); margin-top: 0;">
        <div class="card">
            <div class="card-head">
                <div class="card-title">Submit ToD</div>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post" id="tod-form" novalidate>
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="display:@(ViewData.ModelState.IsValid ? "none" : "block"); margin-bottom:14px;"></div>

                    <div class="form-grid">
                        <label asp-for="Tod.LinkshellId" class="form-grid-label">Linkshell</label>
                        <div>
                            <select asp-for="Tod.LinkshellId" class="form-select" id="linkshell-select">
                                @foreach (var linkshell in Model.Linkshells)
                                {
                                    <option value="@linkshell.Id" selected="@(linkshell.Id == Model.Tod.LinkshellId ? "selected" : null)">@linkshell.LinkshellName</option>
                                }
                            </select>
                            <span asp-validation-for="Tod.LinkshellId" class="field-error"></span>
                        </div>

                        <label asp-for="Tod.MonsterName" class="form-grid-label">Monster</label>
                        <div>
                            <select asp-for="Tod.MonsterName" class="form-select" id="monster-select">
                                <option value="">Select monster name</option>
                                @foreach (var monster in Model.MonsterOptions)
                                {
                                    <option value="@monster" selected="@(string.Equals(monster, Model.Tod.MonsterName, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@monster</option>
                                }
                            </select>
                            <span asp-validation-for="Tod.MonsterName" class="field-error"></span>
                        </div>

                        <label asp-for="Tod.DayNumber" class="form-grid-label">Day #</label>
                        <div>
                            <input asp-for="Tod.DayNumber" class="form-control" type="number" min="0" inputmode="numeric" />
                            <span asp-validation-for="Tod.DayNumber" class="field-error"></span>
                        </div>

                        <label asp-for="Tod.Claim" class="form-grid-label">Claim</label>
                        <div>
                            <select asp-for="Tod.Claim" class="form-select" id="claim-select">
                                <option value="true" selected="@(Model.Tod.Claim ? "selected" : null)">Yes</option>
                                <option value="false" selected="@(!Model.Tod.Claim ? "selected" : null)">No</option>
                            </select>
                        </div>

                        <label asp-for="Tod.Time" class="form-grid-label">ToD</label>
                        <div>
                            <input asp-for="Tod.Time" type="datetime-local" class="form-control" step="1" id="tod-time" value="@Model.Tod.Time?.ToString("yyyy-MM-ddTHH:mm:ss")" />
                            <span asp-validation-for="Tod.Time" class="field-error"></span>
                        </div>

                        <label asp-for="Tod.Cooldown" class="form-grid-label">Cooldown</label>
                        <div>
                            <select asp-for="Tod.Cooldown" class="form-select" id="cooldown-select">
                                @foreach (var cooldown in Model.CooldownOptions)
                                {
                                    <option value="@cooldown" selected="@(string.Equals(cooldown, Model.Tod.Cooldown, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@cooldown</option>
                                }
                            </select>
                            <span asp-validation-for="Tod.Cooldown" class="field-error"></span>
                        </div>

                        <label asp-for="Tod.RepopTime" class="form-grid-label">Repop time</label>
                        <div>
                            <input asp-for="Tod.RepopTime" type="datetime-local" class="form-control" step="1" id="repop-time" value="@Model.Tod.RepopTime?.ToString("yyyy-MM-ddTHH:mm:ss")" readonly />
                        </div>

                        <label asp-for="Tod.Interval" class="form-grid-label">Interval</label>
                        <div>
                            <select asp-for="Tod.Interval" class="form-select" id="interval-select">
                                @foreach (var interval in Model.IntervalOptions)
                                {
                                    <option value="@interval" selected="@(string.Equals(interval, Model.Tod.Interval, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@interval</option>
                                }
                            </select>
                            <span asp-validation-for="Tod.Interval" class="field-error"></span>
                        </div>
                    </div>

                    <input asp-for="NoLoot" type="hidden" id="no-loot" />

                    <div id="loot-section" class="@(Model.Tod.Claim && !Model.NoLoot ? "" : "d-none")" style="margin-top:20px">
                        <div class="card-title" style="margin-bottom:10px">Loot details</div>
                        <div id="loot-rows" style="display:grid;gap:10px">
                            @for (var index = 0; index < Model.TodLootDetails.Count; index++)
                            {
                                var lootDetail = Model.TodLootDetails[index];
                                <div class="loot-detail-row" style="padding:12px;border:1px solid var(--border);border-radius:var(--r-md);background:var(--surface)">
                                    <div class="field-row" style="margin-bottom:0">
                                        <div class="field">
                                            <label class="field-label">Item name</label>
                                            <input type="text" class="form-control" data-field="ItemName" name="TodLootDetails[@index].ItemName" value="@lootDetail.ItemName" />
                                        </div>
                                        <div class="field">
                                            <label class="field-label">Item winner</label>
                                            <select class="form-select" data-field="ItemWinner" name="TodLootDetails[@index].ItemWinner">
                                                <option value="">Select winner</option>
                                                @foreach (var characterName in Model.CharacterNames)
                                                {
                                                    <option value="@characterName" selected="@(string.Equals(characterName, lootDetail.ItemWinner, StringComparison.OrdinalIgnoreCase) ? "selected" : null)">@characterName</option>
                                                }
                                            </select>
                                        </div>
                                        <div class="field">
                                            <label class="field-label">DKP spent</label>
                                            <input type="number" class="form-control" data-field="WinningDkpSpent" name="TodLootDetails[@index].WinningDkpSpent" min="1" value="@lootDetail.WinningDkpSpent" />
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                    <div id="loot-controls" class="@(Model.Tod.Claim ? "" : "d-none")" style="display:flex;justify-content:space-between;gap:8px;margin-top:16px;flex-wrap:wrap">
                        <div style="display:flex;gap:6px;flex-wrap:wrap">
                            <button type="button" class="btn" id="add-loot-row">+ Add loot</button>
                            <button type="button" class="btn ghost" id="remove-loot-row">Remove</button>
                            <button type="button" class="btn ghost" id="no-loot-button">No loot</button>
                        </div>
                        <button type="submit" class="btn primary">Submit ToD</button>
                    </div>

                    <div id="submit-only-row" class="@(Model.Tod.Claim ? "d-none" : "")" style="display:flex;justify-content:flex-end;margin-top:16px">
                        <button type="submit" class="btn primary">Submit ToD</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-head">
                <div class="card-title">Submitted ToDs</div>
                <span class="card-link">@selectedLinkshellName</span>
            </div>
            @if (Model.TodItems.Any())
            {
                <div style="overflow-x:auto">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Day</th>
                                <th>ToD</th>
                                <th>Cooldown</th>
                                <th>Repop</th>
                                <th>Interval</th>
                                <th>Countdown</th>
                                <th style="text-align:right">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.TodItems)
                            {
                                <tr>
                                    <td><span style="color:var(--fg);font-weight:500">@item.MonsterName</span></td>
                                    <td class="num">@(item.DayNumber?.ToString() ?? "—")</td>
                                    <td class="num">@item.TodDisplay</td>
                                    <td>@item.Cooldown</td>
                                    <td class="num">@item.RepopTimeDisplay</td>
                                    <td>@item.Interval</td>
                                    <td>
                                        @if (item.RepopTimeUtc.HasValue)
                                        {
                                            <span class="countdown-timer num" data-end-utc="@item.RepopTimeUtc.Value.ToString("O")" style="color:var(--fg)">—</span>
                                        }
                                        else
                                        {
                                            <span>—</span>
                                        }
                                    </td>
                                    <td style="text-align:right">
                                        <div style="display:inline-flex;gap:6px">
                                            @if (item.LootCount > 0)
                                            {
                                                <button type="button" class="btn sm view-loot-btn" data-id="@item.Id">Loot</button>
                                            }
                                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline" onsubmit="return confirm('Delete this ToD entry?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn sm ghost" style="color:var(--danger)">Delete</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty">No ToD entries found for this linkshell yet.</div>
            }
        </div>
    </div>
}

<div class="modal fade" id="viewLootModal" tabindex="-1" aria-labelledby="viewLootModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewLootModalLabel">Loot details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table class="themed">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Winner</th>
                            <th style="text-align:right">DKP spent</th>
                        </tr>
                    </thead>
                    <tbody id="loot-details-table-body"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const longWindowMonsters = new Set(['Tiamat', 'Jormungand', 'Vrtra']);
            const characterNames = @Html.Raw(JsonSerializer.Serialize(Model.CharacterNames));
            const todTimeInput = document.getElementById('tod-time');
            const monsterSelect = document.getElementById('monster-select');
            const cooldownSelect = document.getElementById('cooldown-select');
            const repopTimeInput = document.getElementById('repop-time');
            const intervalSelect = document.getElementById('interval-select');
            const claimSelect = document.getElementById('claim-select');
            const lootSection = document.getElementById('loot-section');
            const lootRows = document.getElementById('loot-rows');
            const lootControls = document.getElementById('loot-controls');
            const submitOnlyRow = document.getElementById('submit-only-row');
            const noLootInput = document.getElementById('no-loot');
            const addLootRowButton = document.getElementById('add-loot-row');
            const removeLootRowButton = document.getElementById('remove-loot-row');
            const noLootButton = document.getElementById('no-loot-button');
            const linkshellFilter = document.getElementById('linkshell-filter');
            const lootDetailsTableBody = document.getElementById('loot-details-table-body');
            const countdownElements = Array.from(document.querySelectorAll('.countdown-timer'));

            function escapeHtml(value) {
                return String(value ?? '')
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');
            }

            function toDateTimeLocalValue(date) {
                const pad = value => String(value).padStart(2, '0');
                return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}:${pad(date.getSeconds())}`;
            }

            function getCooldownHours() {
                return cooldownSelect.value === '72 Hour' ? 72 : 22;
            }

            function applyMonsterDefaults() {
                if (!monsterSelect.value) return;
                if (longWindowMonsters.has(monsterSelect.value)) {
                    cooldownSelect.value = '72 Hour';
                    intervalSelect.value = '1 Hour';
                } else {
                    cooldownSelect.value = '22 Hour';
                    intervalSelect.value = '10 Min';
                }
            }

            function updateRepopTime() {
                if (!todTimeInput.value) { repopTimeInput.value = ''; return; }
                const todTime = new Date(todTimeInput.value);
                if (Number.isNaN(todTime.getTime())) { repopTimeInput.value = ''; return; }
                const repopTime = new Date(todTime.getTime() + (getCooldownHours() * 60 * 60 * 1000));
                repopTimeInput.value = toDateTimeLocalValue(repopTime);
            }

            function buildWinnerOptions(selectedValue = '') {
                const options = ['<option value="">Select winner</option>'];
                characterNames.forEach(name => {
                    const selected = name === selectedValue ? ' selected' : '';
                    options.push(`<option value="${escapeHtml(name)}"${selected}>${escapeHtml(name)}</option>`);
                });
                return options.join('');
            }

            function createLootRow(itemName = '', itemWinner = '', winningDkpSpent = '') {
                const wrapper = document.createElement('div');
                wrapper.className = 'loot-detail-row';
                wrapper.style.cssText = 'padding:12px;border:1px solid var(--border);border-radius:var(--r-md);background:var(--surface)';
                wrapper.innerHTML = `
                    <div class="field-row" style="margin-bottom:0">
                        <div class="field">
                            <label class="field-label">Item name</label>
                            <input type="text" class="form-control" data-field="ItemName" value="${escapeHtml(itemName)}" />
                        </div>
                        <div class="field">
                            <label class="field-label">Item winner</label>
                            <select class="form-select" data-field="ItemWinner">${buildWinnerOptions(itemWinner)}</select>
                        </div>
                        <div class="field">
                            <label class="field-label">DKP spent</label>
                            <input type="number" class="form-control" data-field="WinningDkpSpent" min="1" value="${escapeHtml(winningDkpSpent)}" />
                        </div>
                    </div>`;
                return wrapper;
            }

            function reindexLootRows() {
                lootRows.querySelectorAll('.loot-detail-row').forEach((row, index) => {
                    row.querySelector('[data-field="ItemName"]').setAttribute('name', `TodLootDetails[${index}].ItemName`);
                    row.querySelector('[data-field="ItemWinner"]').setAttribute('name', `TodLootDetails[${index}].ItemWinner`);
                    row.querySelector('[data-field="WinningDkpSpent"]').setAttribute('name', `TodLootDetails[${index}].WinningDkpSpent`);
                });
            }

            function ensureLootRow() {
                if (!lootRows.querySelector('.loot-detail-row')) {
                    lootRows.appendChild(createLootRow());
                }
                reindexLootRows();
            }

            function resetLootRows() { lootRows.innerHTML = ''; ensureLootRow(); }

            function toggleLootUi() {
                const claimIsYes = claimSelect.value === 'true';
                lootControls.classList.toggle('d-none', !claimIsYes);
                submitOnlyRow.classList.toggle('d-none', claimIsYes);
                if (!claimIsYes) {
                    noLootInput.value = 'false';
                    lootSection.classList.add('d-none');
                    resetLootRows();
                    return;
                }
                if (noLootInput.value === 'true') { lootSection.classList.add('d-none'); return; }
                ensureLootRow();
                lootSection.classList.remove('d-none');
            }

            function formatCountdown(milliseconds) {
                const totalSeconds = Math.max(0, Math.floor(milliseconds / 1000));
                const days = Math.floor(totalSeconds / 86400);
                const hours = Math.floor((totalSeconds % 86400) / 3600);
                const minutes = Math.floor((totalSeconds % 3600) / 60);
                const seconds = totalSeconds % 60;
                return `${days}d ${String(hours).padStart(2, '0')}h ${String(minutes).padStart(2, '0')}m ${String(seconds).padStart(2, '0')}s`;
            }

            function updateCountdowns() {
                const now = Date.now();
                countdownElements.forEach(element => {
                    const endUtc = element.dataset.endUtc;
                    const endTime = Date.parse(endUtc);
                    if (Number.isNaN(endTime)) { element.textContent = '—'; return; }
                    const remaining = endTime - now;
                    element.textContent = remaining <= 0 ? 'Ready' : formatCountdown(remaining);
                });
            }

            monsterSelect?.addEventListener('change', () => { applyMonsterDefaults(); updateRepopTime(); });
            todTimeInput?.addEventListener('change', updateRepopTime);
            cooldownSelect?.addEventListener('change', updateRepopTime);
            claimSelect?.addEventListener('change', toggleLootUi);

            addLootRowButton?.addEventListener('click', () => {
                noLootInput.value = 'false';
                lootSection.classList.remove('d-none');
                lootRows.appendChild(createLootRow());
                reindexLootRows();
            });

            removeLootRowButton?.addEventListener('click', () => {
                const rows = lootRows.querySelectorAll('.loot-detail-row');
                if (rows.length > 1) rows[rows.length - 1].remove();
                else if (rows.length === 1) {
                    rows[0].querySelectorAll('input, select').forEach(input => { input.value = ''; });
                }
                reindexLootRows();
            });

            noLootButton?.addEventListener('click', () => {
                noLootInput.value = 'true';
                lootSection.classList.add('d-none');
                resetLootRows();
            });

            linkshellFilter?.addEventListener('change', () => {
                const url = new URL(window.location.href);
                url.searchParams.set('linkshellId', linkshellFilter.value);
                window.location.assign(url.toString());
            });

            document.querySelectorAll('.view-loot-btn').forEach(button => {
                button.addEventListener('click', async () => {
                    const todId = button.getAttribute('data-id');
                    if (!todId) return;
                    const response = await fetch(`/Tod/GetLootDetails/${todId}`);
                    if (!response.ok) return;
                    const lootDetails = await response.json();
                    lootDetailsTableBody.innerHTML = '';
                    if (!lootDetails.length) {
                        lootDetailsTableBody.innerHTML = '<tr><td colspan="3" class="empty">No loot details found.</td></tr>';
                    } else {
                        lootDetails.forEach(detail => {
                            const row = document.createElement('tr');
                            row.innerHTML = `
                                <td>${escapeHtml(detail.itemName ?? '')}</td>
                                <td>${escapeHtml(detail.itemWinner ?? '')}</td>
                                <td class="num" style="text-align:right">${escapeHtml(detail.winningDkpSpent ?? '')}</td>`;
                            lootDetailsTableBody.appendChild(row);
                        });
                    }
                    const modal = new bootstrap.Modal(document.getElementById('viewLootModal'));
                    modal.show();
                });
            });

            ensureLootRow();
            applyMonsterDefaults();
            updateRepopTime();
            toggleLootUi();
            updateCountdowns();
            window.setInterval(updateCountdowns, 1000);
        });
    </script>
}
