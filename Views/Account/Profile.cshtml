@model ProfileViewModel
@{
    ViewData["Title"] = "Profile";
    var imageSource = Model.ProfileImageData is { Length: > 0 }
        ? $"data:image/png;base64,{Convert.ToBase64String(Model.ProfileImageData)}"
        : null;
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">Profile</h1>
        <div class="page-sub"><span>Your Discord-linked account</span></div>
    </div>
    <div class="page-actions">
        <a class="btn ghost" asp-controller="Dashboard" asp-action="Index">Back to dashboard</a>
    </div>
</div>

<div class="card fade d2" style="padding:20px;max-width:720px">
    <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
        @if (imageSource is not null)
        {
            <div style="display:flex;align-items:center;gap:16px;margin-bottom:20px;padding-bottom:16px;border-bottom:1px solid var(--border)">
                <img src="@imageSource" alt="Profile" style="width:72px;height:72px;border-radius:999px;object-fit:cover;border:1px solid var(--border)" />
                <div>
                    <div style="font-weight:500;color:var(--fg)">@Model.CharacterName</div>
                    <div style="font-size:12px;color:var(--fg-3)">Profile image syncs from Discord</div>
                </div>
            </div>
        }

        <div class="form-grid">
            <div class="field">
                <label asp-for="CharacterName"></label>
                <input asp-for="CharacterName" class="form-control" />
            </div>
            <div class="field">
                <label asp-for="TimeZone">Time zone (IANA)</label>
                <input asp-for="TimeZone" class="form-control" placeholder="America/New_York" />
            </div>
        </div>

        <div style="display:flex;gap:8px;margin-top:20px;padding-top:16px;border-top:1px solid var(--border)">
            <button type="submit" class="btn primary">Save profile</button>
            <a class="btn ghost" asp-controller="Dashboard" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>
