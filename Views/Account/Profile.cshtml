@model ProfileViewModel
@{
    ViewData["Title"] = "Profile";
    var imageSource = Model.ProfileImageData is { Length: > 0 }
        ? $"data:image/png;base64,{Convert.ToBase64String(Model.ProfileImageData)}"
        : null;
}

<div class="row justify-content-center">
    <div class="col-xl-8">
        <div class="card card-shell shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 mb-1">Profile</h1>
                <p class="text-muted mb-4">Manage the app-level profile tied to your Discord-linked account.</p>

                <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data" class="row g-3">
                    <div class="col-12">
                        @if (imageSource is not null)
                        {
                            <img src="@imageSource" alt="Profile image" style="width:96px;height:96px;border-radius:999px;object-fit:cover;border:1px solid rgba(115,164,223,.35)" />
                        }
                    </div>
                    <div class="col-md-6">
                        <label asp-for="CharacterName" class="form-label"></label>
                        <input asp-for="CharacterName" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TimeZone" class="form-label">Time zone (IANA)</label>
                        <input asp-for="TimeZone" class="form-control" placeholder="America/New_York" />
                    </div>
                    <div class="col-12">
                        <div class="form-text text-light-emphasis">
                            Profile image is synced automatically from your Discord avatar.
                        </div>
                    </div>
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save profile</button>
                        <a class="btn btn-outline-light" asp-controller="Dashboard" asp-action="Index">Back to dashboard</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
