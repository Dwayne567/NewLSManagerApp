@model SettingsViewModel
@{
    ViewData["Title"] = "Settings";
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">Settings</h1>
        <div class="page-sub"><span>Choose your primary linkshell context</span></div>
    </div>
    <div class="page-actions">
        <a class="btn ghost" asp-controller="Dashboard" asp-action="Index">Back to dashboard</a>
    </div>
</div>

<div class="card fade d2" style="padding:20px;max-width:720px">
    @if (Model.Linkshells.Count == 0)
    {
        <div class="alert alert-warning" style="margin:0">
            You are not a member of any linkshells yet. <a asp-controller="Linkshell" asp-action="Create" style="color:var(--accent)">Create one now</a>.
        </div>
    }
    else
    {
        <form asp-action="SetPrimaryLinkshell" method="post">
            <div class="field">
                <label for="SelectedLinkshellId">Primary linkshell</label>
                <select class="form-select" id="SelectedLinkshellId" name="SelectedLinkshellId">
                    @foreach (var linkshell in Model.Linkshells)
                    {
                        if (linkshell.Id == Model.SelectedLinkshellId)
                        {
                            <option value="@linkshell.Id" selected>@linkshell.LinkshellName</option>
                        }
                        else
                        {
                            <option value="@linkshell.Id">@linkshell.LinkshellName</option>
                        }
                    }
                </select>
            </div>
            <div style="display:flex;gap:8px;margin-top:20px;padding-top:16px;border-top:1px solid var(--border)">
                <button type="submit" class="btn primary">Save settings</button>
                <a class="btn ghost" asp-controller="Dashboard" asp-action="Index">Cancel</a>
            </div>
        </form>
    }
</div>
