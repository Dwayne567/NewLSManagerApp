@model EventHistory
@{
    ViewData["Title"] = "History details";
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">@Model.EventName</h1>
        <div class="page-sub">
            @if (!string.IsNullOrWhiteSpace(Model.EventType))
            {
                <span>@Model.EventType</span>
                <span>·</span>
            }
            @if (!string.IsNullOrWhiteSpace(Model.EventLocation))
            {
                <span>@Model.EventLocation</span>
                <span>·</span>
            }
            <span>Completed</span>
        </div>
    </div>
    <div class="page-actions">
        <a class="btn ghost" asp-action="Index">Back to history</a>
    </div>
</div>

<div class="grid fade d2">
    <div class="col">
        <div class="card">
            <div class="card-head">
                <div class="card-title">Event details</div>
            </div>
            <div style="padding:4px 16px 16px;display:grid;grid-template-columns:120px 1fr;gap:8px 16px;font-size:13px">
                <div style="color:var(--fg-3)">Type</div><div>@Model.EventType</div>
                <div style="color:var(--fg-3)">Location</div><div>@Model.EventLocation</div>
                <div style="color:var(--fg-3)">Started</div><div>@(Model.StartTime?.ToString("g") ?? "—")</div>
                <div style="color:var(--fg-3)">Ended</div><div>@(Model.EndTime?.ToString("g") ?? "—")</div>
                <div style="color:var(--fg-3)">Duration</div><div class="num">@((Model.Duration ?? 0).ToString("0.##")) h</div>
                <div style="color:var(--fg-3)">DKP/hour</div><div class="num">@(Model.DkpPerHour ?? 0)</div>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.Details))
            {
                <div style="padding:12px 16px;border-top:1px solid var(--border);color:var(--fg-3);font-size:13px">@Model.Details</div>
            }
        </div>
    </div>

    <div class="col">
        <div class="card">
            <div class="card-head">
                <div class="card-title">Participants <span class="tag">@Model.AppUserEventHistories.Count</span></div>
            </div>
            <table class="table themed">
                <thead>
                    <tr>
                        <th>Character</th>
                        <th>Job</th>
                        <th style="text-align:right">Duration</th>
                        <th style="text-align:right">DKP</th>
                        <th>Verification</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var participant in Model.AppUserEventHistories.OrderBy(p => p.CharacterName))
                    {
                        <tr>
                            <td style="font-weight:500">@participant.CharacterName</td>
                            <td>@participant.JobName/@participant.SubJobName</td>
                            <td style="text-align:right;font-family:var(--font-mono)">@((participant.Duration ?? 0).ToString("0.##")) h</td>
                            <td style="text-align:right;font-family:var(--font-mono)" class="num">@((participant.EventDkp ?? 0).ToString("0.##"))</td>
                            <td>
                                @if (participant.IsVerified == true)
                                {
                                    <span class="tag success">Verified</span>
                                }
                                else if (participant.IsVerified == false)
                                {
                                    <span class="tag danger">Denied</span>
                                }
                                else
                                {
                                    <span class="tag">Not reviewed</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
