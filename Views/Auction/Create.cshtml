@model LinkshellManagerDiscordApp.ViewModels.AuctionViewModel
@{
    ViewData["Title"] = "Create Auction";
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">Create auction</h1>
        <div class="page-sub"><span>Set the title, timer, and auction items</span></div>
    </div>
    <div class="page-actions">
        <a class="btn ghost" asp-action="Index">Back</a>
    </div>
</div>

<div class="card fade d2" style="padding:20px">
    <form asp-action="Create" method="post" id="auctionForm">
        <div class="form-grid">
            <div class="field">
                <label asp-for="LinkshellId">Linkshell</label>
                <select asp-for="LinkshellId" class="form-select">
                    @foreach (var linkshell in Model.Linkshells)
                    {
                        <option value="@linkshell.Id">@linkshell.LinkshellName</option>
                    }
                </select>
            </div>
            <div class="field">
                <label asp-for="Auction.AuctionTitle">Auction title</label>
                <input asp-for="Auction.AuctionTitle" class="form-control" />
                <span asp-validation-for="Auction.AuctionTitle" style="color:var(--danger);font-size:11px"></span>
            </div>
            <div class="field">
                <label asp-for="Auction.StartTime">Start time</label>
                <input asp-for="Auction.StartTime" type="datetime-local" class="form-control" />
                <span asp-validation-for="Auction.StartTime" style="color:var(--danger);font-size:11px"></span>
            </div>
            <div class="field">
                <label asp-for="Auction.EndTime">End time</label>
                <input asp-for="Auction.EndTime" type="datetime-local" class="form-control" />
                <span asp-validation-for="Auction.EndTime" style="color:var(--danger);font-size:11px"></span>
            </div>
        </div>

        <div style="margin-top:20px;padding-top:16px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
            <div>
                <h2 style="font-size:14px;font-weight:600;color:var(--fg);margin:0 0 2px">Auction items</h2>
                <div style="font-size:12px;color:var(--fg-3)">Add at least one item with its opening bid.</div>
            </div>
            <button type="button" class="btn ghost sm" id="addAuctionItemButton">+ Add item</button>
        </div>

        <div id="auctionItems" style="display:grid;gap:12px">
            @for (var i = 0; i < Model.AuctionItems.Count; i++)
            {
                <div class="card auction-item-row" style="padding:12px" data-index="@i">
                    <input asp-for="AuctionItems[i].Id" type="hidden" />
                    <div class="form-grid">
                        <div class="field">
                            <label asp-for="AuctionItems[i].ItemName">Item name</label>
                            <input asp-for="AuctionItems[i].ItemName" class="form-control" />
                            <span asp-validation-for="AuctionItems[i].ItemName" style="color:var(--danger);font-size:11px"></span>
                        </div>
                        <div class="field">
                            <label asp-for="AuctionItems[i].ItemType">Item type</label>
                            <input asp-for="AuctionItems[i].ItemType" class="form-control" />
                        </div>
                        <div class="field">
                            <label asp-for="AuctionItems[i].StartingBidDkp">Starting bid</label>
                            <input asp-for="AuctionItems[i].StartingBidDkp" class="form-control" />
                            <span asp-validation-for="AuctionItems[i].StartingBidDkp" style="color:var(--danger);font-size:11px"></span>
                        </div>
                        <div class="field" style="grid-column:1/-1">
                            <label asp-for="AuctionItems[i].Notes">Notes</label>
                            <input asp-for="AuctionItems[i].Notes" class="form-control" />
                        </div>
                        <div class="field" style="grid-column:1/-1">
                            <button type="button" class="btn ghost sm remove-auction-item">Remove item</button>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div style="display:flex;gap:8px;margin-top:20px;padding-top:16px;border-top:1px solid var(--border)">
            <button type="submit" class="btn primary">Create auction</button>
            <a class="btn ghost" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const itemsContainer = document.getElementById('auctionItems');
            const addItemButton = document.getElementById('addAuctionItemButton');

            const renumberRows = () => {
                const rows = itemsContainer.querySelectorAll('.auction-item-row');
                rows.forEach((row, index) => {
                    row.dataset.index = index;
                    row.querySelectorAll('input, label, span').forEach((element) => {
                        ['name', 'id', 'for'].forEach((attribute) => {
                            const value = element.getAttribute(attribute);
                            if (!value) { return; }
                            element.setAttribute(attribute, value
                                .replace(/AuctionItems\[\d+\]/g, `AuctionItems[${index}]`)
                                .replace(/AuctionItems_\d+__/g, `AuctionItems_${index}__`));
                        });
                    });
                });
            };

            addItemButton.addEventListener('click', () => {
                const index = itemsContainer.querySelectorAll('.auction-item-row').length;
                const wrapper = document.createElement('div');
                wrapper.className = 'card auction-item-row';
                wrapper.style.padding = '12px';
                wrapper.dataset.index = index;
                wrapper.innerHTML = `
                    <input type="hidden" name="AuctionItems[${index}].Id" value="0" />
                    <div class="form-grid">
                        <div class="field"><label for="AuctionItems_${index}__ItemName">Item name</label><input class="form-control" id="AuctionItems_${index}__ItemName" name="AuctionItems[${index}].ItemName" /></div>
                        <div class="field"><label for="AuctionItems_${index}__ItemType">Item type</label><input class="form-control" id="AuctionItems_${index}__ItemType" name="AuctionItems[${index}].ItemType" /></div>
                        <div class="field"><label for="AuctionItems_${index}__StartingBidDkp">Starting bid</label><input class="form-control" id="AuctionItems_${index}__StartingBidDkp" name="AuctionItems[${index}].StartingBidDkp" type="number" /></div>
                        <div class="field" style="grid-column:1/-1"><label for="AuctionItems_${index}__Notes">Notes</label><input class="form-control" id="AuctionItems_${index}__Notes" name="AuctionItems[${index}].Notes" /></div>
                        <div class="field" style="grid-column:1/-1"><button type="button" class="btn ghost sm remove-auction-item">Remove item</button></div>
                    </div>`;
                itemsContainer.appendChild(wrapper);
            });

            itemsContainer.addEventListener('click', (event) => {
                const trigger = event.target.closest('.remove-auction-item');
                if (!trigger) { return; }
                const rows = itemsContainer.querySelectorAll('.auction-item-row');
                if (rows.length <= 1) { return; }
                trigger.closest('.auction-item-row')?.remove();
                renumberRows();
            });
        })();
    </script>
}
