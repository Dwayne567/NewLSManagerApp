@model List<LinkshellManagerDiscordApp.ViewModels.AuctionViewModel>

@{
    ViewData["Title"] = "Auctions";
    var characterName = ViewBag.CharacterName as string ?? "User";
    var currentUserId = ViewBag.CurrentUserId as string ?? string.Empty;
    var currentTime = ViewBag.CurrentTime is DateTime current ? current : DateTime.Now;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Linkshell auctions</h1>
        <p class="text-muted mb-0">Create, bid on, and close auctions for your current primary linkshell.</p>
    </div>
    <div class="d-flex gap-2">
        <a class="btn btn-outline-light" asp-controller="AuctionHistory" asp-action="Index">Auction history</a>
        <a class="btn btn-primary" asp-action="Create">Create auction</a>
    </div>
</div>

@if (TempData["AuctionError"] is string auctionError)
{
    <div class="alert alert-danger">@auctionError</div>
}

<div class="card card-shell shadow-sm">
    <div class="card-body">
        @if (!Model.Any())
        {
            <p class="text-muted mb-0">No auctions are available on your current primary linkshell.</p>
        }
        else
        {
            @foreach (var auction in Model)
            {
                var auctionStarted = auction.Auction.StartedAt.HasValue || (auction.Auction.StartTime.HasValue && currentTime >= auction.Auction.StartTime.Value);
                var auctionLive = auctionStarted && (!auction.Auction.EndTime.HasValue || currentTime < auction.Auction.EndTime.Value);
                var auctionEnded = auction.Auction.EndTime.HasValue && currentTime >= auction.Auction.EndTime.Value;
                var canManage = string.Equals(auction.Auction.CreatedByUserId, currentUserId, StringComparison.OrdinalIgnoreCase);
                var canEdit = canManage && !auctionStarted;
                var canStart = canManage && !auction.Auction.StartedAt.HasValue && !auctionStarted && !auctionEnded;
                var canClose = canManage && auctionEnded;

                <section class="mb-5">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h2 class="h4 mb-1">@auction.Auction.AuctionTitle</h2>
                            <div class="text-muted small">
                                Created by @auction.Auction.CreatedBy
                                @if (auction.Auction.StartTime.HasValue || auction.Auction.EndTime.HasValue)
                                {
                                    <span> | Scheduled @(auction.Auction.StartTime?.ToString("g") ?? "Unknown") - @(auction.Auction.EndTime?.ToString("g") ?? "Unknown")</span>
                                }
                                @if (auction.Auction.StartedAt.HasValue)
                                {
                                    <span> | Started @auction.Auction.StartedAt?.ToString("g")</span>
                                }
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            @if (canEdit)
                            {
                                <a class="btn btn-outline-light btn-sm" asp-action="Edit" asp-route-id="@auction.Auction.Id">Edit</a>
                            }
                            @if (canClose)
                            {
                                <form asp-action="EndAuction" method="post">
                                    <input type="hidden" name="auctionId" value="@auction.Auction.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm">Close auction</button>
                                </form>
                            }
                            else if (canStart)
                            {
                                <form asp-action="StartAuction" method="post">
                                    <input type="hidden" name="auctionId" value="@auction.Auction.Id" />
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-success btn-sm">Start auction</button>
                                </form>
                            }
                        </div>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle" data-auction-id="@auction.Auction.Id">
                            <thead>
                                <tr>
                                    <th>Item</th>
                                    <th>Type</th>
                                    <th>Starting DKP</th>
                                    <th>Highest bid</th>
                                    <th>Highest bidder</th>
                                    <th>Start</th>
                                    <th>End</th>
                                    <th>Timer</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in auction.AuctionItems)
                                {
                                    <tr>
                                        <td>
                                            <div>@item.ItemName</div>
                                            @if (!string.IsNullOrWhiteSpace(item.Notes))
                                            {
                                                <div class="text-muted small">@item.Notes</div>
                                            }
                                        </td>
                                        <td>@(item.ItemType ?? "Unspecified")</td>
                                        <td>@item.StartingBidDkp</td>
                                        <td>@(item.CurrentHighestBid ?? 0)</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.CurrentHighestBidder) ? "No bids" : item.CurrentHighestBidder)</td>
                                        <td class="date-cell" data-date="@item.StartTime?.ToString("yyyy-MM-ddTHH:mm:ss")"></td>
                                        <td class="date-cell" data-date="@item.EndTime?.ToString("yyyy-MM-ddTHH:mm:ss")"></td>
                                        <td>
                                            <span class="countdown-timer"
                                                  data-start-time="@item.StartTime?.ToString("yyyy-MM-ddTHH:mm:ss")"
                                                  data-end-time="@item.EndTime?.ToString("yyyy-MM-ddTHH:mm:ss")"></span>
                                        </td>
                                        <td class="text-end">
                                            <div class="d-flex flex-wrap justify-content-end gap-2">
                                                <button type="button" class="btn btn-outline-light btn-sm viewBidsButton" data-item-id="@item.Id">View bids</button>
                                                @if (auctionLive)
                                                {
                                                    <button
                                                        type="button"
                                                        class="btn btn-success btn-sm makeBidButton"
                                                        data-item-id="@item.Id"
                                                        data-item-name="@item.ItemName"
                                                        data-current-highest-bid="@item.CurrentHighestBid"
                                                        data-starting-bid="@item.StartingBidDkp">
                                                        Bid
                                                    </button>
                                                }
                                                @if (canEdit)
                                                {
                                                    <form asp-action="RemoveItem" method="post" class="d-inline">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="id" value="@item.Id" />
                                                        <button type="submit" class="btn btn-outline-danger btn-sm">Remove</button>
                                                    </form>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (canEdit)
                    {
                        <div class="d-flex justify-content-end">
                            <button type="button"
                                    class="btn btn-outline-light btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#addItemModal"
                                    data-auction-id="@auction.Auction.Id">
                                Add item
                            </button>
                        </div>
                    }
                    else if (!auctionStarted && !auctionEnded)
                    {
                        <p class="text-muted small mb-0">This auction is configured and waiting for a manual start.</p>
                    }
                </section>
            }
        }
    </div>
</div>

<div class="modal fade" id="addItemModal" tabindex="-1" aria-labelledby="addItemModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title" id="addItemModalLabel">Add auction item</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-action="AddItem" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="auctionId" name="auctionId" />
                    <div class="mb-3">
                        <label class="form-label" for="ItemName">Item name</label>
                        <input type="text" class="form-control" id="ItemName" name="ItemName" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="ItemType">Item type</label>
                        <input type="text" class="form-control" id="ItemType" name="ItemType" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="StartingBidDkp">Starting DKP</label>
                        <input type="number" class="form-control" id="StartingBidDkp" name="StartingBidDkp" min="0" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="Notes">Notes</label>
                        <input type="text" class="form-control" id="Notes" name="Notes" />
                    </div>
                    <button type="submit" class="btn btn-primary">Add item</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewBidsModal" tabindex="-1" aria-labelledby="viewBidsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title" id="viewBidsModalLabel">Bid history</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table class="table table-dark align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Character</th>
                            <th>Bid</th>
                            <th>When</th>
                        </tr>
                    </thead>
                    <tbody id="bidsTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="makeBidModal" tabindex="-1" aria-labelledby="makeBidModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content bg-dark text-light">
            <div class="modal-header">
                <h5 class="modal-title" id="makeBidModalLabel">Make a bid</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="makeBidForm" asp-action="MakeBid" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="auctionItemId" name="auctionItemId" />
                    <div class="mb-3">
                        <label class="form-label" for="itemName">Item name</label>
                        <input type="text" class="form-control" id="itemName" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="characterName">Character name</label>
                        <input type="text" class="form-control" id="characterName" value="@characterName" readonly />
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="bidAmount">Bid amount (DKP)</label>
                        <input type="number" class="form-control" id="bidAmount" name="bidAmount" min="1" required />
                    </div>
                    <button type="submit" class="btn btn-primary">Submit bid</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const addItemButtons = document.querySelectorAll('[data-bs-target="#addItemModal"]');
            addItemButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    document.getElementById('auctionId').value = button.getAttribute('data-auction-id');
                });
            });

            const viewBidsButtons = document.querySelectorAll('.viewBidsButton');
            viewBidsButtons.forEach((button) => {
                button.addEventListener('click', async () => {
                    const response = await fetch(`/Auction/GetBids?auctionItemId=${button.getAttribute('data-item-id')}`);
                    if (!response.ok) {
                        return;
                    }

                    const bids = await response.json();
                    const tbody = document.getElementById('bidsTableBody');
                    tbody.innerHTML = '';

                    if (!Array.isArray(bids) || bids.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="3" class="text-muted">No bids yet.</td></tr>';
                    } else {
                        bids.forEach((bid) => {
                            const row = document.createElement('tr');
                            row.innerHTML = `<td>${bid.characterName}</td><td>${bid.bidAmount}</td><td>${bid.createdAt ?? ''}</td>`;
                            tbody.appendChild(row);
                        });
                    }

                    new bootstrap.Modal(document.getElementById('viewBidsModal')).show();
                });
            });

            const makeBidButtons = document.querySelectorAll('.makeBidButton:not([disabled])');
            let minimumBid = 0;
            makeBidButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    const itemId = button.getAttribute('data-item-id');
                    const itemName = button.getAttribute('data-item-name');
                    const currentHighestBid = parseInt(button.getAttribute('data-current-highest-bid') || '0', 10);
                    const startingBid = parseInt(button.getAttribute('data-starting-bid') || '0', 10);
                    minimumBid = Math.max(currentHighestBid, startingBid);

                    document.getElementById('auctionItemId').value = itemId;
                    document.getElementById('itemName').value = itemName;
                    document.getElementById('bidAmount').value = String(minimumBid + 1);

                    new bootstrap.Modal(document.getElementById('makeBidModal')).show();
                });
            });

            document.getElementById('makeBidForm')?.addEventListener('submit', (event) => {
                const bidAmount = parseInt(document.getElementById('bidAmount').value || '0', 10);
                if (bidAmount <= minimumBid) {
                    event.preventDefault();
                    alert(`Bid amount must be greater than ${minimumBid}.`);
                }
            });

            const dateElements = document.querySelectorAll('.date-cell');
            dateElements.forEach((element) => {
                const dateValue = element.getAttribute('data-date');
                if (!dateValue) {
                    element.textContent = 'Unknown';
                    return;
                }

                const date = new Date(dateValue);
                element.textContent = date.toLocaleString();
            });

            const countdownTimers = document.querySelectorAll('.countdown-timer');
            countdownTimers.forEach((timer) => {
                const startTime = timer.getAttribute('data-start-time');
                const endTime = timer.getAttribute('data-end-time');
                if (!startTime || !endTime) {
                    timer.textContent = 'No timer';
                    return;
                }

                const startDate = new Date(startTime);
                const endDate = new Date(endTime);
                const formatRemaining = (remainingMs) => {
                    const totalSeconds = Math.max(0, Math.floor(remainingMs / 1000));
                    const hours = Math.floor(totalSeconds / 3600);
                    const minutes = Math.floor((totalSeconds % 3600) / 60);
                    const seconds = totalSeconds % 60;
                    return `${hours}h ${minutes}m ${seconds}s`;
                };

                const tick = () => {
                    const now = new Date();
                    if (now < startDate) {
                        timer.textContent = `Starts in ${formatRemaining(startDate.getTime() - now.getTime())}`;
                        return;
                    }

                    const remaining = endDate.getTime() - now.getTime();
                    if (remaining <= 0) {
                        timer.textContent = 'Auction ended';
                        return;
                    }

                    timer.textContent = formatRemaining(remaining);
                };

                tick();
                setInterval(tick, 1000);
            });
        })();
    </script>
}
