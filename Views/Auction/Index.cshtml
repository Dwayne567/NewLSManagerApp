@model List<LinkshellManagerDiscordApp.ViewModels.AuctionViewModel>
@{
    ViewData["Title"] = "Auctions";
    var characterName = ViewBag.CharacterName as string ?? "User";
    var currentUserId = ViewBag.CurrentUserId as string ?? string.Empty;
    var currentTime = ViewBag.CurrentTime is DateTime current ? current : DateTime.Now;
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">Linkshell Auctions</h1>
        <div class="page-sub">
            <span><span class="num">@Model.Count</span> auctions</span>
            <span class="live-dot">Live</span>
        </div>
    </div>
    <div class="page-actions">
        <a class="btn ghost" asp-controller="AuctionHistory" asp-action="Index">Auction history</a>
        <a class="btn primary" asp-action="Create">+ Create auction</a>
    </div>
</div>

@if (TempData["AuctionError"] is string auctionError)
{
    <div class="alert alert-danger fade d2">@auctionError</div>
}

@if (!Model.Any())
{
    <div class="card fade d2">
        <div class="empty">
            <div style="font-size:15px;color:var(--fg);font-weight:500;margin-bottom:6px">No auctions available</div>
            <div style="margin-bottom:12px">Your current primary linkshell has no active auctions.</div>
            <a class="btn primary" asp-action="Create">Create auction</a>
        </div>
    </div>
}
else
{
    <div class="fade d2" style="display:grid;gap:16px">
        @foreach (var auction in Model)
        {
            var auctionStarted = auction.Auction.StartedAt.HasValue || (auction.Auction.StartTime.HasValue && currentTime >= auction.Auction.StartTime.Value);
            var auctionLive = auctionStarted && (!auction.Auction.EndTime.HasValue || currentTime < auction.Auction.EndTime.Value);
            var auctionEnded = auction.Auction.EndTime.HasValue && currentTime >= auction.Auction.EndTime.Value;
            var canManage = string.Equals(auction.Auction.CreatedByUserId, currentUserId, StringComparison.OrdinalIgnoreCase);
            var canEdit = canManage && !auctionStarted;
            var canStart = canManage && !auction.Auction.StartedAt.HasValue && !auctionStarted && !auctionEnded;
            var canClose = canManage && auctionEnded;

            <div class="card">
                <div class="card-head">
                    <div style="display:flex;flex-direction:column;gap:4px">
                        <div class="card-title">
                            @auction.Auction.AuctionTitle
                            @if (auctionLive)
                            {
                                <span class="tag success">Live</span>
                            }
                            else if (auctionEnded)
                            {
                                <span class="tag warning">Ended</span>
                            }
                            else
                            {
                                <span class="tag">Scheduled</span>
                            }
                        </div>
                        <div style="font-size:12px;color:var(--fg-3)">
                            <span>by @auction.Auction.CreatedBy</span>
                            @if (auction.Auction.StartTime.HasValue || auction.Auction.EndTime.HasValue)
                            {
                                <span class="dot"> · </span>
                                <span>@(auction.Auction.StartTime?.ToString("g") ?? "TBD") → @(auction.Auction.EndTime?.ToString("g") ?? "TBD")</span>
                            }
                            @if (auction.Auction.StartedAt.HasValue)
                            {
                                <span class="dot"> · </span>
                                <span>Started @auction.Auction.StartedAt?.ToString("g")</span>
                            }
                        </div>
                    </div>
                    <div style="display:flex;gap:6px;flex-wrap:wrap">
                        @if (canEdit)
                        {
                            <a class="btn ghost sm" asp-action="Edit" asp-route-id="@auction.Auction.Id">Edit</a>
                        }
                        @if (canClose)
                        {
                            <form asp-action="EndAuction" method="post" style="display:inline">
                                <input type="hidden" name="auctionId" value="@auction.Auction.Id" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn primary sm" style="background:var(--danger);border-color:var(--danger)">Close</button>
                            </form>
                        }
                        else if (canStart)
                        {
                            <form asp-action="StartAuction" method="post" style="display:inline">
                                <input type="hidden" name="auctionId" value="@auction.Auction.Id" />
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn primary sm">Start</button>
                            </form>
                        }
                    </div>
                </div>

                <table class="table themed" data-auction-id="@auction.Auction.Id">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Type</th>
                            <th>Starting</th>
                            <th>Highest</th>
                            <th>Bidder</th>
                            <th>Timer</th>
                            <th style="text-align:right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in auction.AuctionItems)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:500">@item.ItemName</div>
                                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                                    {
                                        <div style="color:var(--fg-4);font-size:11px">@item.Notes</div>
                                    }
                                </td>
                                <td><span class="tag">@(item.ItemType ?? "—")</span></td>
                                <td class="num">@item.StartingBidDkp</td>
                                <td class="num">@(item.CurrentHighestBid ?? 0)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.CurrentHighestBidder) ? "—" : item.CurrentHighestBidder)</td>
                                <td style="font-family:var(--font-mono);font-size:12px">
                                    <span class="countdown-timer"
                                          data-start-time="@item.StartTime?.ToString("yyyy-MM-ddTHH:mm:ss")"
                                          data-end-time="@item.EndTime?.ToString("yyyy-MM-ddTHH:mm:ss")"></span>
                                </td>
                                <td style="text-align:right">
                                    <div style="display:flex;justify-content:flex-end;gap:4px;flex-wrap:wrap">
                                        <button type="button" class="btn ghost sm viewBidsButton" data-item-id="@item.Id">Bids</button>
                                        @if (auctionLive)
                                        {
                                            <button type="button"
                                                    class="btn primary sm makeBidButton"
                                                    data-item-id="@item.Id"
                                                    data-item-name="@item.ItemName"
                                                    data-current-highest-bid="@item.CurrentHighestBid"
                                                    data-starting-bid="@item.StartingBidDkp">Bid</button>
                                        }
                                        @if (canEdit)
                                        {
                                            <form asp-action="RemoveItem" method="post" style="display:inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn ghost sm">Remove</button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                @if (canEdit)
                {
                    <div style="padding:12px 16px;border-top:1px solid var(--border);display:flex;justify-content:flex-end">
                        <button type="button"
                                class="btn ghost sm"
                                data-bs-toggle="modal"
                                data-bs-target="#addItemModal"
                                data-auction-id="@auction.Auction.Id">+ Add item</button>
                    </div>
                }
                else if (!auctionStarted && !auctionEnded)
                {
                    <div style="padding:12px 16px;border-top:1px solid var(--border);font-size:12px;color:var(--fg-3)">Waiting for manual start.</div>
                }
            </div>
        }
    </div>
}

<div class="modal fade" id="addItemModal" tabindex="-1" aria-labelledby="addItemModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addItemModalLabel">Add auction item</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form asp-action="AddItem" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="auctionId" name="auctionId" />
                    <div class="field"><label for="ItemName">Item name</label><input type="text" class="form-control" id="ItemName" name="ItemName" required /></div>
                    <div class="field"><label for="ItemType">Item type</label><input type="text" class="form-control" id="ItemType" name="ItemType" /></div>
                    <div class="field"><label for="StartingBidDkp">Starting DKP</label><input type="number" class="form-control" id="StartingBidDkp" name="StartingBidDkp" min="0" required /></div>
                    <div class="field"><label for="Notes">Notes</label><input type="text" class="form-control" id="Notes" name="Notes" /></div>
                    <button type="submit" class="btn primary" style="margin-top:8px">Add item</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="viewBidsModal" tabindex="-1" aria-labelledby="viewBidsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="viewBidsModalLabel">Bid history</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <table class="table themed">
                    <thead>
                        <tr><th>Character</th><th>Bid</th><th>When</th></tr>
                    </thead>
                    <tbody id="bidsTableBody"></tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="makeBidModal" tabindex="-1" aria-labelledby="makeBidModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="makeBidModalLabel">Make a bid</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="makeBidForm" asp-action="MakeBid" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="auctionItemId" name="auctionItemId" />
                    <div class="field"><label for="itemName">Item name</label><input type="text" class="form-control" id="itemName" readonly /></div>
                    <div class="field"><label for="characterName">Character name</label><input type="text" class="form-control" id="characterName" value="@characterName" readonly /></div>
                    <div class="field"><label for="bidAmount">Bid amount (DKP)</label><input type="number" class="form-control" id="bidAmount" name="bidAmount" min="1" required /></div>
                    <button type="submit" class="btn primary" style="margin-top:8px">Submit bid</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const addItemButtons = document.querySelectorAll('[data-bs-target="#addItemModal"]');
            addItemButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    document.getElementById('auctionId').value = button.getAttribute('data-auction-id');
                });
            });

            const viewBidsButtons = document.querySelectorAll('.viewBidsButton');
            viewBidsButtons.forEach((button) => {
                button.addEventListener('click', async () => {
                    const response = await fetch(`/Auction/GetBids?auctionItemId=${button.getAttribute('data-item-id')}`);
                    if (!response.ok) { return; }
                    const bids = await response.json();
                    const tbody = document.getElementById('bidsTableBody');
                    tbody.innerHTML = '';
                    if (!Array.isArray(bids) || bids.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="3" style="color:var(--fg-3)">No bids yet.</td></tr>';
                    } else {
                        bids.forEach((bid) => {
                            const row = document.createElement('tr');
                            row.innerHTML = `<td>${bid.characterName}</td><td class="num">${bid.bidAmount}</td><td>${bid.createdAt ?? ''}</td>`;
                            tbody.appendChild(row);
                        });
                    }
                    new bootstrap.Modal(document.getElementById('viewBidsModal')).show();
                });
            });

            const makeBidButtons = document.querySelectorAll('.makeBidButton:not([disabled])');
            let minimumBid = 0;
            makeBidButtons.forEach((button) => {
                button.addEventListener('click', () => {
                    const itemId = button.getAttribute('data-item-id');
                    const itemName = button.getAttribute('data-item-name');
                    const currentHighestBid = parseInt(button.getAttribute('data-current-highest-bid') || '0', 10);
                    const startingBid = parseInt(button.getAttribute('data-starting-bid') || '0', 10);
                    minimumBid = Math.max(currentHighestBid, startingBid);
                    document.getElementById('auctionItemId').value = itemId;
                    document.getElementById('itemName').value = itemName;
                    document.getElementById('bidAmount').value = String(minimumBid + 1);
                    new bootstrap.Modal(document.getElementById('makeBidModal')).show();
                });
            });

            document.getElementById('makeBidForm')?.addEventListener('submit', (event) => {
                const bidAmount = parseInt(document.getElementById('bidAmount').value || '0', 10);
                if (bidAmount <= minimumBid) {
                    event.preventDefault();
                    alert(`Bid amount must be greater than ${minimumBid}.`);
                }
            });

            const countdownTimers = document.querySelectorAll('.countdown-timer');
            countdownTimers.forEach((timer) => {
                const startTime = timer.getAttribute('data-start-time');
                const endTime = timer.getAttribute('data-end-time');
                if (!startTime || !endTime) { timer.textContent = 'No timer'; return; }
                const startDate = new Date(startTime);
                const endDate = new Date(endTime);
                const formatRemaining = (remainingMs) => {
                    const totalSeconds = Math.max(0, Math.floor(remainingMs / 1000));
                    const hours = Math.floor(totalSeconds / 3600);
                    const minutes = Math.floor((totalSeconds % 3600) / 60);
                    const seconds = totalSeconds % 60;
                    return `${hours}h ${minutes}m ${seconds}s`;
                };
                const tick = () => {
                    const now = new Date();
                    if (now < startDate) {
                        timer.textContent = `in ${formatRemaining(startDate.getTime() - now.getTime())}`;
                        return;
                    }
                    const remaining = endDate.getTime() - now.getTime();
                    if (remaining <= 0) { timer.textContent = 'Ended'; return; }
                    timer.textContent = formatRemaining(remaining);
                };
                tick();
                setInterval(tick, 1000);
            });
        })();
    </script>
}
