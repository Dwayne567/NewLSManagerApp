@model Linkshell
@{
    ViewData["Title"] = "Delete linkshell";
    var blockedReason = ViewBag.DeleteBlockedReason as string;
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">Delete linkshell</h1>
        <div class="page-sub"><span>Confirm removal of this linkshell</span></div>
    </div>
    <div class="page-actions">
        <a class="btn ghost" asp-action="Index">Cancel</a>
    </div>
</div>

<div class="card fade d2" style="padding:20px;max-width:640px;border-color:var(--danger)">
    @if (!string.IsNullOrWhiteSpace(blockedReason))
    {
        <div class="alert alert-warning" style="margin-bottom:16px">@blockedReason</div>
    }
    else
    {
        <div class="alert alert-danger" style="margin-bottom:16px">
            This will remove <strong>@Model.LinkshellName</strong>, its live events, and its event history. This cannot be undone.
        </div>
    }
    <form asp-action="Delete" method="post" style="display:flex;gap:8px">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn primary" style="background:var(--danger);border-color:var(--danger)" disabled="@(!string.IsNullOrWhiteSpace(blockedReason))">Delete linkshell</button>
        <a class="btn ghost" asp-action="Index">Cancel</a>
    </form>
</div>
