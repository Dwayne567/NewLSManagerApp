@model Linkshell
@{
    ViewData["Title"] = "Delete linkshell";
}

<div class="row justify-content-center">
    <div class="col-xl-6">
        <div class="card card-shell shadow-sm border-danger">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">Delete linkshell</h1>
                @if (!string.IsNullOrWhiteSpace(ViewBag.DeleteBlockedReason as string))
                {
                    <div class="alert alert-warning mb-3">@ViewBag.DeleteBlockedReason</div>
                }
                else
                {
                    <p>This will remove <strong>@Model.LinkshellName</strong>, its live events, and its event history from the restored first-slice data model.</p>
                }
                <form asp-action="Delete" method="post" class="d-flex gap-2">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger" disabled="@(!string.IsNullOrWhiteSpace(ViewBag.DeleteBlockedReason as string))">Delete linkshell</button>
                    <a class="btn btn-outline-light" asp-action="Index">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
