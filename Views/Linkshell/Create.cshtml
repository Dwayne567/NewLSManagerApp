@model LinkshellViewModel
@{
    ViewData["Title"] = "Create linkshell";
}

<div class="row justify-content-center">
    <div class="col-xl-7">
        <div class="card card-shell shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">Create linkshell</h1>
                <form asp-action="Create" method="post" class="row g-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="col-12">
                        <label asp-for="LinkshellName" class="form-label"></label>
                        <input asp-for="LinkshellName" class="form-control" />
                        <span asp-validation-for="LinkshellName" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Details" class="form-label"></label>
                        <textarea asp-for="Details" class="form-control" rows="5"></textarea>
                    </div>
                    <div class="col-12 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Create</button>
                        <a class="btn btn-outline-light" asp-action="Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
