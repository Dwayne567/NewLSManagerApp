@model LinkshellViewModel
@{
    ViewData["Title"] = "Edit linkshell";
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">Edit linkshell</h1>
        <div class="page-sub"><span>@Model.LinkshellName</span></div>
    </div>
    <div class="page-actions">
        <a class="btn ghost" asp-action="Index">Cancel</a>
    </div>
</div>

<div class="card fade d2" style="padding:20px;max-width:720px">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="margin-bottom:12px"></div>
        <div class="field">
            <label asp-for="LinkshellName"></label>
            <input asp-for="LinkshellName" class="form-control" />
            <span asp-validation-for="LinkshellName" style="color:var(--danger);font-size:11px"></span>
        </div>
        <div class="field">
            <label asp-for="Details"></label>
            <textarea asp-for="Details" class="form-control" rows="5"></textarea>
        </div>
        <div style="display:flex;gap:8px;margin-top:16px;padding-top:12px;border-top:1px solid var(--border)">
            <button type="submit" class="btn primary">Save</button>
            <a class="btn ghost" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>
