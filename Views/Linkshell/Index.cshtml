@model IEnumerable<Linkshell>
@{
    ViewData["Title"] = "Linkshells";
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">Linkshells</h1>
        <div class="page-sub">
            <span><span class="num">@Model.Count()</span> total</span>
        </div>
    </div>
    <div class="page-actions">
        <a class="btn primary" asp-action="Create">+ Create linkshell</a>
    </div>
</div>

<div class="card fade d2">
    @if (!Model.Any())
    {
        <div class="empty">
            <div style="font-size:15px;color:var(--fg);font-weight:500;margin-bottom:6px">No linkshells yet</div>
            <div style="margin-bottom:12px">Create or join a linkshell to start managing memberships and events.</div>
            <a class="btn primary" asp-action="Create">Create linkshell</a>
        </div>
    }
    else
    {
        <table class="table themed">
            <thead>
                <tr>
                    <th>Linkshell</th>
                    <th>Status</th>
                    <th style="text-align:right">Members</th>
                    <th style="text-align:right">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var linkshell in Model)
                {
                    var status = linkshell.Status ?? "Active";
                    var statusClass = status.Equals("Active", StringComparison.OrdinalIgnoreCase) ? "success" : "";
                    <tr>
                        <td>
                            <div style="font-weight:500">@linkshell.LinkshellName</div>
                            @if (!string.IsNullOrWhiteSpace(linkshell.Details))
                            {
                                <div style="color:var(--fg-4);font-size:11px">@linkshell.Details</div>
                            }
                        </td>
                        <td><span class="tag @statusClass">@status</span></td>
                        <td style="text-align:right" class="num">@(linkshell.TotalMembers ?? 0)</td>
                        <td style="text-align:right">
                            <div style="display:flex;justify-content:flex-end;gap:4px">
                                <a class="btn ghost sm" asp-action="Details" asp-route-id="@linkshell.Id">Details</a>
                                <a class="btn ghost sm" asp-action="Edit" asp-route-id="@linkshell.Id">Edit</a>
                                <a class="btn ghost sm" asp-action="Delete" asp-route-id="@linkshell.Id">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
