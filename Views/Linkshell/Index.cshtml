@model IEnumerable<Linkshell>
@{
    ViewData["Title"] = "Linkshells";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Linkshells</h1>
        <p class="text-muted mb-0">Manage the linkshells attached to your current app user.</p>
    </div>
    <a class="btn btn-primary" asp-action="Create">Create linkshell</a>
</div>

<div class="card card-shell shadow-sm">
    <div class="card-body">
        @if (!Model.Any())
        {
            <p class="text-muted mb-0">You have not created or joined a linkshell yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Status</th>
                            <th>Members</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var linkshell in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold">@linkshell.LinkshellName</div>
                                <div class="small text-muted">@linkshell.Details</div>
                            </td>
                            <td>@(linkshell.Status ?? "Active")</td>
                            <td>@(linkshell.TotalMembers ?? 0)</td>
                            <td class="text-end d-flex justify-content-end gap-2">
                                <a class="btn btn-outline-light btn-sm" asp-action="Details" asp-route-id="@linkshell.Id">Details</a>
                                <a class="btn btn-outline-light btn-sm" asp-action="Edit" asp-route-id="@linkshell.Id">Edit</a>
                                <a class="btn btn-outline-danger btn-sm" asp-action="Delete" asp-route-id="@linkshell.Id">Delete</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
