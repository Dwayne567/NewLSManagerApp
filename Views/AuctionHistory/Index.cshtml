@model List<LinkshellManagerDiscordApp.ViewModels.AuctionHistoryViewModel>
@{
    ViewData["Title"] = "Auction History";
}

<div class="page-head fade d1">
    <div>
        <h1 class="page-title">Auction history</h1>
        <div class="page-sub">
            <span><span class="num">@Model.Count</span> closed auctions</span>
        </div>
    </div>
    <div class="page-actions">
        <a class="btn ghost" asp-controller="Auction" asp-action="Index">Back to auctions</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card fade d2">
        <div class="empty">No auction history yet.</div>
    </div>
}
else
{
    <div class="fade d2" style="display:grid;gap:16px">
        @foreach (var auctionHistory in Model)
        {
            <div class="card">
                <div class="card-head">
                    <div style="display:flex;flex-direction:column;gap:4px">
                        <div class="card-title">
                            @auctionHistory.AuctionHistory.AuctionTitle
                            <span class="tag">Closed</span>
                        </div>
                        <div style="font-size:12px;color:var(--fg-3)">
                            <span>by @auctionHistory.AuctionHistory.CreatedBy</span>
                            <span class="dot"> · </span>
                            <span>@(auctionHistory.AuctionHistory.StartTime?.ToString("g") ?? "TBD") → @(auctionHistory.AuctionHistory.EndTime?.ToString("g") ?? "TBD")</span>
                            @if (auctionHistory.AuctionHistory.StartedAt.HasValue)
                            {
                                <span class="dot"> · </span>
                                <span>Started @auctionHistory.AuctionHistory.StartedAt?.ToString("g")</span>
                            }
                            <span class="dot"> · </span>
                            <span>Closed @auctionHistory.AuctionHistory.ClosedAt.ToString("g")</span>
                        </div>
                    </div>
                </div>

                <table class="table themed">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th>Type</th>
                            <th>Starting</th>
                            <th>Winning</th>
                            <th>Winner</th>
                            <th>Status</th>
                            <th style="text-align:right">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in auctionHistory.AuctionItems)
                        {
                            var status = item.Status ?? "Pending";
                            var statusClass = status.Equals("Received", StringComparison.OrdinalIgnoreCase) ? "success" : "warning";
                            <tr>
                                <td>
                                    <div style="font-weight:500">@item.ItemName</div>
                                    @if (!string.IsNullOrWhiteSpace(item.Notes))
                                    {
                                        <div style="color:var(--fg-4);font-size:11px">@item.Notes</div>
                                    }
                                </td>
                                <td><span class="tag">@(item.ItemType ?? "—")</span></td>
                                <td class="num">@item.StartingBidDkp</td>
                                <td class="num">@(item.EndingBidDkp ?? item.CurrentHighestBid ?? 0)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.CurrentHighestBidder) ? "—" : item.CurrentHighestBidder)</td>
                                <td><span class="tag @statusClass">@status</span></td>
                                <td style="text-align:right">
                                    @if (status == "Pending")
                                    {
                                        <form asp-action="UpdateItemStatus" method="post" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="itemId" value="@item.Id" />
                                            <button type="submit" class="btn ghost sm">Mark received</button>
                                        </form>
                                    }
                                    else if (status.Equals("Received", StringComparison.OrdinalIgnoreCase))
                                    {
                                        <form asp-action="UndoItemStatus" method="post" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="itemId" value="@item.Id" />
                                            <button type="submit" class="btn ghost sm">Undo</button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}
